    "queryValue": "WITH post_data AS (\n    SELECT \n        password,\n        MIN(date_full) AS first_post_date\n    FROM \n        webhook_negburo\n    WHERE \n        channel_id = '12556306'\n    GROUP BY \n        password\n),\n-- Список лидов с паролями\nlead_data AS (\n    SELECT \n        password,\n        COUNT(DISTINCT leads_id) AS unique_leads,\n        COUNT(DISTINCT CASE WHEN qual = 1 THEN leads_id END) AS qualified_leads,\n        COUNT(DISTINCT CASE WHEN booking_event = 1 THEN leads_id END) AS booked_leads\n    FROM \n        perfomance_all_leads\n    WHERE \n        (creation_date >= {{interval_from}}\n            AND creation_date <= {{interval_to}})\n        AND password IS NOT NULL\n        -- В основной воронке и в валидации\n        AND (pipeline_id = '5987164' OR (pipeline_id = '7309478' AND status_id != 142))\n        -- Вычитаем мусорные лиды\n        AND (reason != 'НЕ клиент/Мусор/Застройщики' OR reason IS NULL)\n    GROUP BY \n        password\n)\n\nSELECT \n    pd.first_post_date AS \"Дата первого поста\",\n    COALESCE(t.password_org, ld.password) AS \"Пароль\",\n    ld.unique_leads AS \"Лиды\",\n    ld.qualified_leads AS \"Квалы\",\n    ld.booked_leads AS \"Брони\",\n    CASE \n        WHEN ld.unique_leads > 0 THEN \n            CAST((ld.qualified_leads::float / ld.unique_leads) AS NUMERIC(5,4))\n        ELSE \n            0\n    END AS \"CRQ\"\nFROM \n    lead_data ld\nINNER JOIN \n    post_data pd ON ld.password = pd.password\nLEFT JOIN \n    webhook_negburo t ON ld.password = t.password \n                      AND t.date_full = pd.first_post_date\n                      AND t.channel_id = '12556306' \nWHERE\n    t.channel_id = '12556306'  -- Фильтрация по каналу в основном запросе\nORDER BY \n    ld.qualified_leads DESC",
    "queries": [],
