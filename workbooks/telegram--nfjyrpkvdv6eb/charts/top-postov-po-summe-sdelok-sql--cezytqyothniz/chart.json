    "queryValue": "-- Топ худших паролей ОАЭ в квал (CRQ)\n\nSELECT \n    MIN(t.date_full) AS \"Дата поста\",\n    t.password_org AS \"Пароль\",\n   -- COUNT(DISTINCT p.leads_id) AS \"Лиды\",\n   -- SUM(qual) AS \"Квалы\",\n    SUM(booking_event) AS \"Брони\",\n    SUM(deal_amount) AS \"Сумма сделок\"\nFROM \n    webhook_negburo t\nLEFT JOIN \n    perfomance_all_leads p ON p.password = t.password\nWHERE \n    -- Посты за 2024 год\n    (creation_date >= {{interval_from}}\n            AND creation_date <= {{interval_to}})\n    -- Только с основного канала\n    AND channel_id = '12556306'\n    -- Смотрим в воронке \"Клиенты\"\n    AND (p.pipeline_id = '5987164'\n        -- Смотрим в валидации тоже, но не в статусе \"успешно\"\n        OR (p.pipeline_id = '7309478' AND p.status_id != 142))\n   AND booking_event = 1\n   -- AND (reason != 'НЕ клиент/Мусор/Застройщики'\n     --   OR reason IS NULL)\nGROUP BY \n    t.password_org\nHAVING \n    -- Там где больше 5 лидов\n   SUM(booking_event) >= 1\n    -- И не было броней\n    --AND SUM(booking_event) = 0\nORDER BY \n    \"Сумма сделок\" DESC;",
    "queries": [],
