    "queryValue": "SELECT al.creation_date AS \"Дата CRM\",\n       COUNT(al.leads_id) AS \"Лидов\",\n       SUM(al.qual) AS \"Квал\"\nFROM public.perfomance_all_leads al\nLEFT JOIN public.perfomance_sourcetag s ON s.lead_id = al.leads_id\nWHERE s.prioritized_sourcetag = 'tg_bot_negburo'\nGROUP BY al.creation_date\nORDER BY al.creation_date;\n",
