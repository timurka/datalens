          "aggregation_locked": true,
          "formula": "IF [day_bucket] = 0 THEN -- Служебный бакет. Показываем все лиды\n    NULL\n\n-- По дням\nELSE\n    -- Конверсии\n    IF [metrics_bool] THEN\n        -- Кумулятивные\n        IF [csum] THEN\n            [Кум. конверсия]\n\n        ELSE\n            [Дневная конверсия]\n        END\n\n    -- Целые\n    ELSE\n        IF [csum] THEN\n            [Кум. квалы]\n        ELSE\n            [Дневные квалы]\n        END\n    END\n\nEND",
