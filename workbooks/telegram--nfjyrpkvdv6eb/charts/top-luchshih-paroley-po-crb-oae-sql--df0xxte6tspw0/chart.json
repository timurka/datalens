    "queryValue": "-- Топ худших паролей ОАЭ в квал (CRQ)\n\nSELECT \n    MIN(t.date_full) AS \"Дата поста\",\n    t.password_org AS \"Пароль\",\n    COUNT(DISTINCT p.leads_id) AS \"Лиды\",\n    SUM(qual) AS \"Квалы\",\n    SUM(booking_event) AS \"Брони\",\n    CASE \n        WHEN COUNT(DISTINCT p.leads_id) > 0 THEN \n            CAST((SUM(CASE WHEN p.booking_event = 1 THEN 1 ELSE 0 END)::float / COUNT(DISTINCT p.leads_id)) AS NUMERIC(5,4))\n        ELSE \n            0\n    END AS CRB\nFROM \n    webhook_negburo t\nLEFT JOIN \n    perfomance_all_leads p ON p.password = t.password\nWHERE \n    -- Посты за 2024 год\n    (creation_date >= {{interval_from}}\n            AND creation_date <= {{interval_to}})\n    -- Только с основного канала\n    AND channel_id = '12556306'\n    -- Смотрим в воронке \"Клиенты\"\n    AND (p.pipeline_id = '5987164'\n        -- Смотрим в валидации тоже, но не в статусе \"успешно\"\n        OR (p.pipeline_id = '7309478' AND p.status_id != 142))\n   -- AND (reason != 'НЕ клиент/Мусор/Застройщики'\n     --   OR reason IS NULL)\nGROUP BY \n    t.password_org\nHAVING \n    -- Там где больше 5 лидов\n   SUM(booking_event) >= 2\n    -- И не было броней\n    --AND SUM(booking_event) = 0\nORDER BY \n    CRB DESC, \n    \"Лиды\" DESC;",
    "queries": [],
