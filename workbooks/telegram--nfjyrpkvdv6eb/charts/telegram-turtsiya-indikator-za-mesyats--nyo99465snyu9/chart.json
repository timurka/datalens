    "queryValue": "SELECT \n  SUM(leads)::INTEGER || ' / ' || \n  SUM(quals)::INTEGER || ' / ' || \n  CASE \n    WHEN SUM(leads) > 0 THEN ROUND(SUM(quals)::NUMERIC / SUM(leads) * 100, 1)\n    ELSE 0\n  END || '%' AS \"Лиды / Квалы / CRQ за этот месяц с TG\"\nFROM perfomance_svodny_actions\nWHERE geo = 'Турция'\n  --AND pipeline_id = 6674022\n  AND creation_date >= date_trunc('month', CURRENT_DATE)\n  AND creation_date < date_trunc('month', CURRENT_DATE + INTERVAL '1 month')\n  AND utmsource = 'zakupka'",
