          "id": "f88f4e11-13cd-11f0-85a2-537dfe4cec9c",
          "parameter_hash": "ee70ed6827ea1bc6",
          "connection_id": "g8crkisikyyc4",
          "title": "category_logs_leads",
          "managed_by": "user",
          "index_info_set": null,
          "source_type": "PG_SUBSELECT",
          "virtual": false,
          "parameters": {
            "subsql": "WITH logs AS (\n    -- Уже смэтченные лиды по логам входа и выхода\n    SELECT zakupki_id,\n           COUNT(DISTINCT user_id) AS joins,\n           COUNT(date_left) AS lefts,\n           SUM(leads) AS leads,\n           SUM(total_qual) AS total_qual,\n           SUM(total_book) AS total_book,\n           SUM(total_deal_amount) AS total_deal_amount,\n           -- Вычисляем lifetime как разницу между датой выхода и датой входа в днях\n           ROUND(AVG(CASE \n               WHEN date_left IS NOT NULL THEN EXTRACT(DAY FROM date_left - date_join)\n               ELSE NULL \n           END), 2) AS lifetime,\n           -- Считаем количество пользователей, которые пробыли 3 и более дней\n           COUNT(DISTINCT CASE \n               WHEN date_left IS NOT NULL AND EXTRACT(DAY FROM date_left - date_join) >= 3 THEN user_id\n               ELSE NULL \n           END) AS days3\n    FROM telegram_logs_leads\n    GROUP BY zakupki_id\n)\n\nSELECT date,\n       city,\n       channel_name,\n       channel_link,\n       cost,\n       i.category,\n       i.adv_reach,\n\n       CASE \n           WHEN i.adv_reach > 0 THEN ROUND(c.cost / i.adv_reach::numeric, 2) * 1000\n           ELSE NULL \n       END AS CPM,\n\n       CASE \n           WHEN l.joins > 0 THEN ROUND(c.cost / l.joins::numeric, 2) \n           ELSE NULL \n       END AS CPF,\n\n       l.joins,\n       l.lefts,\n       l.lifetime,\n       l.days3,\n\n       CASE \n            WHEN l.joins > 0 THEN ROUND(l.days3::numeric / l.joins, 2) * 100\n            ELSE NULL \n       END AS days3_per_join,\n\n       CASE \n           WHEN l.days3 > 0 THEN ROUND(c.cost / l.days3::numeric, 2) \n           ELSE NULL \n       END AS cost_per_days3,\n\n       l.leads,\n       l.total_qual,\n       l.total_book,\n       l.total_deal_amount,\n\n       CASE \n           WHEN l.days3 > 0 THEN ROUND(l.leads::numeric / l.days3 * 100, 2) \n           ELSE NULL \n       END AS CRL,\n\n       CASE \n           WHEN l.leads > 0 THEN ROUND(c.cost / l.leads::numeric, 2) \n           ELSE NULL \n       END AS CPL,\n\n       CASE \n           WHEN l.leads > 0 THEN ROUND(l.total_qual::numeric / l.leads, 2) \n           ELSE NULL \n       END AS CRQL,\n\n       CASE \n           WHEN l.total_qual > 0 THEN ROUND(c.cost / l.total_qual::numeric, 2) \n           ELSE NULL \n       END AS CPQL\n\nFROM zakupki c\nLEFT JOIN zakupki_info i ON c.channel_link_part = i.channel\nLEFT JOIN logs l ON c.id = l.zakupki_id\nWHERE i.category IS NOT NULL\n      AND i.category NOT IN ('404', '500', 'moder', 'NaN')\nORDER BY c.date DESC"
          },
          "valid": true
        }
      ],
