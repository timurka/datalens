          "subsql": "SELECT wn.date_full,\n       wn.password_org,\n       NULLIF(COUNT(pal.password), 0) AS leads,\n       NULLIF(SUM(pal.is_qualified), 0) AS sum_quals,\n       NULLIF(SUM(pal.is_booked), 0) AS sum_books,\n       NULLIF(SUM(pal.qual_priority_a), 0) AS sum_quals_a,\n       NULLIF(SUM(pal.qual_priority_b), 0) AS sum_quals_b,\n       NULLIF(SUM(pal.qual_priority_c), 0) AS sum_quals_c,\n       NULLIF(SUM(pal.budget_usd), 0) AS sum_deals_usd,\n       CASE \n           WHEN COUNT(pal.password) > 0 THEN \n               NULLIF(CAST(SUM(pal.is_qualified) AS FLOAT) / COUNT(pal.password), 0)\n           ELSE NULL\n       END AS CRQ\nFROM tgstat_posts wn\nLEFT JOIN msc_perfomance_all_leads pal ON wn.password = pal.password\nWHERE wn.channel_id = 16190063 -- Канал МСК\n      AND wn.password IS NOT NULL\n\t  AND wn.is_deleted != 1 -- Удаленные не смотрим\nGROUP BY wn.date_full, wn.password_org\nORDER BY wn.date_full DESC"
        },
        "virtual": false,
