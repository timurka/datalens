        {
          "index_info_set": null,
          "parameters": {
            "subsql": "SELECT\n    t.date_full,\n    t.date AS datetime, -- Оригинальный Unix timestamp\n    t.password_org,\n    p.creation_date,     -- Дата создания лида (тип date)\n    p.crm_id,\n    p.crm_id AS id,\n    p.qual,\n    p.qual_priority_a,\n    p.qual_priority_b,\n    p.qual_priority_c,\n    p.booking_event,\n    p.revenue,\n    COALESCE(p.deal_amount, 0) AS deal_amount\nFROM\n    core.tgstat_posts t\nLEFT JOIN\n    mart.perfomance_all_leads p ON LOWER(p.password) = LOWER(t.password)\n                         -- Сравниваем дату создания лида с ДАТОЙ поста\n                         AND p.creation_date >= date(to_timestamp(t.date))\n                         AND p.pipeline_id = 6674022 -- Воронка Москвы\n     --                    AND p.utmsource = 'zakupka'\nWHERE\n    t.is_deleted != 1\n    AND t.channel_id = 16190063\n    AND t.password IS NOT NULL\nORDER BY\n    t.date DESC"
          },
          "virtual": false,
          "id": "761aa3f0-8a32-11ef-aaae-3b787cc5c998",
