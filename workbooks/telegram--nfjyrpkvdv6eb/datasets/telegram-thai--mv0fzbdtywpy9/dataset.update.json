        {
          "raw_schema": [],
          "connection_id": "mm62jghuy9vg6",
          "title": "password_thai",
          "source_type": "PG_SUBSELECT",
          "index_info_set": null,
          "valid": false,
          "managed_by": "user",
          "virtual": false,
          "id": "eebe7451-87c9-11ef-8b35-056b9e7ad375",
          "parameter_hash": "a48ebd5b0c4ce761",
          "parameters": {
            "subsql": "SELECT wn.date_full,\n       wn.password_org,\n       NULLIF(COUNT(pal.password), 0) AS leads,\n       NULLIF(SUM(pal.qual), 0) AS sum_quals,\n       NULLIF(SUM(pal.booking_event), 0) AS sum_books,\n       NULLIF(SUM(pal.qual_priority_a), 0) AS sum_quals_a,\n       NULLIF(SUM(pal.qual_priority_b), 0) AS sum_quals_b,\n       NULLIF(SUM(pal.qual_priority_c), 0) AS sum_quals_c,\n       NULLIF(SUM(pal.deal_amount), 0) AS sum_deals_usd,\n       CASE \n           WHEN COUNT(pal.password) > 0 THEN \n               NULLIF(CAST(SUM(pal.qual) AS FLOAT) / COUNT(pal.password), 0)\n           ELSE NULL\n       END AS CRQ\nFROM tgstat_posts wn\nLEFT JOIN perfomance_all_leads pal ON wn.password = pal.password\n                                     AND pal.pipeline_id = '8650122'\nWHERE wn.channel_id = 19593488 -- Канал Тай\n      AND wn.password IS NOT NULL\n      AND wn.is_deleted != 1 -- Удаленные не смотрим\n\t  AND date_full > '2024-09-16' -- Старые дубайские посты не надо\nGROUP BY wn.date_full, wn.password_org\nORDER BY wn.date_full DESC"
          }
        },
