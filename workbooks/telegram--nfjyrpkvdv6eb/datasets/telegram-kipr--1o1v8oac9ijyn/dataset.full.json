          "subsql": "SELECT\n    t.date_full,\n    t.date AS datetime,\n    t.password_org,\n    -- Поля из первой воронки (валидация)\n    pl.crm_id AS parent_lead_id,\n    pl.creation_date,\n    pl.crm_id AS parent_crm_id,\n    -- Поля из второй воронки (кипр)\n    pq.crm_id AS id,\n    pq.qual,\n    pq.qual_priority_a,\n    pq.qual_priority_b,\n    pq.qual_priority_c,\n    pq.booking_event,\n    COALESCE(pq.deal_amount, 0) AS deal_amount\nFROM tgstat_posts t\n    -- Привязываем лиды из валидационной воронки\n    LEFT JOIN perfomance_all_leads pl\n           ON  pl.password = t.password\n           AND pl.utm_campaign = 'cyprus'\n           AND pl.utmsource = 'zakupka'\n           AND pl.pipeline_id = '7309478'\n    -- Привязываем квалы/брони из кипрской воронки\n    LEFT JOIN perfomance_all_leads pq\n           ON  pq.duplicate_lead_id = pl.crm_id\n           AND pq.pipeline_id = '8976054'\nWHERE\n    t.is_deleted != 1\n    AND t.channel_id = 26274908  -- канал Кипра\n    AND t.password IS NOT NULL\nORDER BY t.date DESC"
        },
        "connection_id": "g8crkisikyyc4",
