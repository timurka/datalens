          "virtual": false,
          "id": "69baada1-ee9e-11ef-b5f0-db6ce391ea44",
          "parameter_hash": "5592238ef5653f8e",
          "parameters": {
            "subsql": "SELECT t.date_full,\n       t.date AS datetime,\n       t.password_org,\n       p.creation_date,\n       p.crm_id,\n       p.crm_id AS id,\n       p.qual,\n       p.qual_priority_a,\n       p.qual_priority_b,\n       p.qual_priority_c,\n       p.booking_event,\n       COALESCE(p.deal_amount, 0) AS deal_amount\nFROM tgstat_posts t\nLEFT JOIN perfomance_all_leads p ON LOWER(p.password) = LOWER(t.password)\n                         AND p.creation_date >= date(to_timestamp(t.date))\n                         AND p.pipeline_id = 9155686\n   -- AND p.utmsource = 'zakupka'\nWHERE t.is_deleted != 1 -- Удаленные не смотрим\n      AND t.channel_id = 27586089 -- Канал Турции\n\t  AND t.password IS NOT NULL\nORDER BY t.date DESC"
          }
        }
      ],
