    "revision_id": "5nFtPB3bBENavzCqrMQbFr",
    "sources": [
      {
        "source_type": "PG_SUBSELECT",
        "parameters": {
          "subsql": "-- Выборка лида с категориями\nWITH categorized_leads AS (\n    -- Выборка для категории \"Лид-магнит\"\n    SELECT DISTINCT\n        p.leads_id, -- ID лида\n        p.crm_id, -- CRM ID\n        p.creation_date, -- Дата создания лида\n        p.qual, -- Квалификация лида\n        p.password, -- Пароль лида\n        p.booking_event, -- Событие бронирования\n        p.qual_priority_a, -- Приоритет квалификации A\n        p.qual_priority_b, -- Приоритет квалификации B\n        p.qual_priority_c, -- Приоритет квалификации C\n        w.date_full AS password_creation_date, -- Дата создания пароля\n        'Лид-магнит' AS category -- Назначаемая категория\n    FROM\n        perfomance_all_leads p\n    INNER JOIN\n        webhook_negburo w ON p.password = w.password\n    WHERE\n        p.password IS NOT NULL AND p.password <> ''\n        AND lower(w.text) LIKE '%полезныематериалы%'\n\n    UNION ALL\n\n    -- Выборка для категории \"Проект\"\n    SELECT DISTINCT\n        p.leads_id,\n        p.crm_id,\n        p.creation_date,\n        p.qual,\n        p.password,\n        p.booking_event,\n        p.qual_priority_a,\n        p.qual_priority_b,\n        p.qual_priority_c,\n        w.date_full AS password_creation_date,\n        'Проект' AS category\n    FROM\n        perfomance_all_leads p\n    INNER JOIN\n        webhook_negburo w ON p.password = w.password\n    WHERE\n        p.password IS NOT NULL AND p.password <> ''\n        AND (lower(w.text) LIKE '%продажаоаэ%' OR lower(w.text) LIKE '%вторичныйрынок%')\n\n    UNION ALL\n\n    -- Выборка для категории \"Закреп\"\n    SELECT DISTINCT\n        p.leads_id,\n        p.crm_id,\n        p.creation_date,\n        p.qual,\n        p.password,\n        p.booking_event,\n        p.qual_priority_a,\n        p.qual_priority_b,\n        p.qual_priority_c,\n        w.date_full AS password_creation_date,\n        'Закреп' AS category\n    FROM\n        perfomance_all_leads p\n    INNER JOIN\n        webhook_negburo w ON p.password = w.password\n    WHERE\n        p.password IS NOT NULL AND p.password <> ''\n        AND utmsource = 'zakupka'\n        AND (\n            lower(p.password) LIKE '%получить подбор от аналитика%'\n            OR lower(p.password) LIKE '%20 объектов для инвеста%'\n            OR lower(p.password) LIKE '%оформить emirates id%'\n            OR lower(p.password) LIKE '%весенний инвест%'\n            OR lower(p.password) LIKE '%5 объектов до 300 тыс $%'\n        )\n\n    UNION ALL\n\n    -- Выборка для категории \"Закупка\"\n    SELECT DISTINCT\n        p.leads_id,\n        p.crm_id,\n        p.creation_date,\n        p.qual,\n        p.password,\n        p.booking_event,\n        p.qual_priority_a,\n        p.qual_priority_b,\n        p.qual_priority_c,\n        w.date_full AS password_creation_date,\n        'Закупка' AS category\n    FROM\n        perfomance_all_leads p\n    INNER JOIN\n        webhook_negburo w ON p.password = w.password\n    WHERE\n        p.password IS NOT NULL AND p.password <> ''\n        AND p.utmsource = 'zakupka'\n        AND p.creation_date > w.date_full + INTERVAL '3 days'\n\n    UNION ALL\n\n    -- Выборка для категории \"Другое\"\n    SELECT DISTINCT\n        p.leads_id,\n        p.crm_id,\n        p.creation_date,\n        p.qual,\n        p.password,\n        p.booking_event,\n        p.qual_priority_a,\n        p.qual_priority_b,\n        p.qual_priority_c,\n        CAST(NULL AS DATE) AS password_creation_date, -- Явное приведение типа для NULL\n        'Другое' AS category\n    FROM\n        perfomance_all_leads p\n    LEFT JOIN\n        webhook_negburo w ON p.password = w.password\n    WHERE\n        p.utmsource = 'zakupka'\n        AND p.reason NOT ILIKE '%мусор%'\n        AND p.reason NOT ILIKE '%работу%'\n        AND w.password IS NULL -- Условие для паролей, не найденных в webhook_negburo\n)\n\n-- Вывод результатов с возможным дублированием категорий\nSELECT\n    leads_id, -- Идентификатор лида\n    crm_id,\n    creation_date, -- Дата создания лида\n    qual, -- Квалификация лида\n    password, -- Пароль лида\n    booking_event, -- Событие бронирования\n    qual_priority_a, -- Приоритет квалификации A\n    qual_priority_b, -- Приоритет квалификации B\n    qual_priority_c, -- Приоритет квалификации C\n    password_creation_date, -- Дата создания пароля\n    category -- Категория\nFROM\n    categorized_leads\nORDER BY\n    creation_date DESC, leads_id"
        },
