          "connection_id": "mm62jghuy9vg6",
          "title": "password_georgia",
          "managed_by": "user",
          "index_info_set": null,
          "source_type": "PG_SUBSELECT",
          "virtual": false,
          "parameters": {
            "subsql": "SELECT t.date_full,\n       t.date AS datetime,\n       t.password_org,\n       p.creation_date,\n       p.crm_id,\n       p.crm_id AS id,\n       p.qual,\n       p.qual_priority_a,\n       p.qual_priority_b,\n       p.qual_priority_c,\n       p.booking_event,\n       COALESCE(p.deal_amount, 0) AS deal_amount\nFROM core.tgstat_posts t\nLEFT JOIN mart.perfomance_all_leads p ON LOWER(p.password) = LOWER(t.password)\n                         AND p.creation_date >= date(to_timestamp(t.date))\n                         AND p.pipeline_id = 8966666\n   -- AND p.utmsource = 'zakupka'\nWHERE t.is_deleted != 1 -- Удаленные не смотрим\n      AND t.channel_id = 26343788 -- Канал Грузии\n\t  AND t.password IS NOT NULL\nORDER BY t.date DESC"
          },
          "valid": true
        }
      ],
