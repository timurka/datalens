          "parameter_hash": "715ae0e18060f7fe",
          "title": "password_bali2",
          "virtual": false,
          "managed_by": "user",
          "parameters": {
            "subsql": "SELECT t.date_full,\n       t.date AS datetime,\n       t.password_org,\n       p.creation_date,\n       p.crm_id,\n       p.crm_id AS id,\n       p.qual,\n       p.qual_priority_a,\n       p.qual_priority_b,\n       p.qual_priority_c,\n       p.booking_event,\n       COALESCE(p.deal_amount, 0) AS deal_amount\nFROM core.tgstat_posts t\nLEFT JOIN mart.perfomance_all_leads p ON LOWER(p.password) = LOWER(t.password)\n                         AND p.creation_date >= date(to_timestamp(t.date))\n                         AND p.pipeline_id = 8650122 -- Воронка Азии\n   --AND p.utmsource = 'zakupka'\n  -- AND geo = 'Индонезия'\nWHERE t.is_deleted != 1 -- Удаленные не смотрим\n      AND t.channel_id = 19992887 -- Канал Бали\n\t  AND t.password IS NOT NULL\nORDER BY t.date DESC"
          },
