      "sources": [
        {
          "source_type": "PG_SUBSELECT",
          "parameters": {
            "subsql": "SELECT t.date_full,\n       t.date AS datetime,\n       t.password_org,\n       p.creation_date,\n       p.crm_id,\n       p.crm_id AS id,\n       p.qual,\n       p.qual_priority_a,\n       p.qual_priority_b,\n       p.qual_priority_c,\n       p.booking_event,\n       COALESCE(p.deal_amount, 0) AS deal_amount\nFROM tgstat_posts t\nLEFT JOIN perfomance_all_leads p ON LOWER(p.password) = LOWER(t.password)\n                         AND p.creation_date >= date(to_timestamp(t.date))\n                         AND p.pipeline_id = 9004298\n   -- AND p.utmsource = 'zakupka'\nWHERE t.is_deleted != 1 -- Удаленные не смотрим\n      AND t.channel_id = 26346251 -- Канал Сочи\n\t  AND t.password IS NOT NULL\nORDER BY t.date DESC"
          },
          "parameter_hash": "835dfa8c32244d2c",
          "virtual": false,
