      "sources": [
        {
          "parameters": {
            "subsql": "-- Вычисляем разницу между квалом и первой подпиской\n\nWITH earliest_telegram_entry AS (\n  -- Выбираем первую подписку по пользователю с непустым invite_link_name\n  SELECT DISTINCT ON (user_id)\n    user_id,\n    date_join,\n    geo,\n    invite_link_name\n  FROM mart.telegram_logs_leads\n  WHERE date_join IS NOT NULL\n    AND invite_link_name ILIKE '%[TG]%'\n  ORDER BY user_id, date_join ASC\n),\n\nqual_data AS (\n  -- Вычисляем разницу между квалом и первой подпиской\n  SELECT\n    p.geo AS geo_qual,\n    p.contacts_amo_id,\n    p.date_qual,\n    t.date_join,\n    (p.date_qual::date - t.date_join::date) AS days_join_to_qual,\n    DATE_TRUNC('month', p.date_qual) AS qual_month,\n    t.user_id,\n    t.geo AS geo_join,\n    t.invite_link_name\n  FROM mart.perfomance_all_leads p\n  LEFT JOIN core.amo_contacts a ON p.contacts_amo_id = a.contacts_amo_id AND a.account_id = p.account_id\n  LEFT JOIN earliest_telegram_entry t ON a.telegram_id = t.user_id\n  WHERE p.qual = 1\n    AND p.date_qual IS NOT NULL\n    AND t.date_join IS NOT NULL\n    AND p.date_qual::date >= t.date_join::date\n),\n\nmonthly_medians AS (\n  -- Вычисляем медиану разницы между квалом и первой подпиской по месяцам\n  SELECT\n    qual_month,\n    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY days_join_to_qual) AS median_days_join_to_qual_month\n  FROM qual_data\n  GROUP BY qual_month\n),\n\nmonthly_geo_medians AS (\n  -- Вычисляем медиану разницы между квалом и первой подпиской по месяцам и гео\n  SELECT\n    qual_month,\n    geo_qual,\n    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY days_join_to_qual) AS median_days_join_to_qual_month_geo\n  FROM qual_data\n  GROUP BY qual_month, geo_qual\n)\n\nSELECT\n  q.geo_qual,\n  q.contacts_amo_id,\n  DATE(q.date_qual) AS date_qual,\n  DATE(q.date_join) AS date_join,\n  q.days_join_to_qual,\n  m.median_days_join_to_qual_month,\n  mg.median_days_join_to_qual_month_geo,\n  q.user_id,\n  q.geo_join,\n  q.invite_link_name\nFROM qual_data q\nLEFT JOIN monthly_medians m ON q.qual_month = m.qual_month\nLEFT JOIN monthly_geo_medians mg ON q.qual_month = mg.qual_month AND q.geo_qual = mg.geo_qual\nORDER BY q.date_qual DESC\n"
          },
