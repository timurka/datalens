          "parameter_hash": "880d0f82212e39f7",
          "managed_by": "user",
          "title": "SQL",
          "virtual": false,
          "id": "6992a4e1-0970-11ef-8214-0d55d61261bf",
          "source_type": "PG_SUBSELECT",
          "index_info_set": null,
          "parameters": {
            "subsql": "-- Определение категории \"Проект\" по наличию хештега в посте\nWITH project_passwords AS (\n    SELECT DISTINCT\n        LOWER(TRIM(p.password)) AS password  -- Обработка и уникализация паролей\n    FROM\n        perfomance_all_leads p\n    INNER JOIN\n        webhook_negburo w ON p.password = w.password  -- Соединение с таблицей webhook\n    WHERE\n        p.password IS NOT NULL AND p.password <> ''  -- Исключение пустых и нулевых значений\n        AND (LOWER(w.text) LIKE '%продажаоаэ%' OR LOWER(w.text) LIKE '%вторичныйрынок%')  -- Условия для классификации \"Проект\"\n)\n\n-- Основной запрос для получения данных о лиде с присоединением категории\nSELECT \n    p.creation_date,        -- Дата создания лида\n    p.crm_id,\n    p.password,             -- Пароль лида\n    p.qual,                 -- Качество лида\n    p.booking_event,        -- Информация о бронировании события\n    -- Выбор категории по порядку: из таблицы (брать последнее при пересечении), \"Проект\", иначе \"Другое\" \n    COALESCE(MAX(s.category), CASE WHEN proj.password IS NOT NULL THEN 'Проект' END, 'Другое') AS category  \nFROM \n    perfomance_all_leads p\nLEFT JOIN \n    sheets_report_75689 s ON LOWER(TRIM(p.password)) = LOWER(TRIM(s.password))  -- Соединение с таблицей отчетов\n    AND p.creation_date >= DATE(s.date_start)  -- Условие по дате начала действия\n    AND (p.creation_date <= DATE(s.date_end) OR DATE(s.date_end) IS NULL)  -- Условие по дате окончания или его отсутствию\nLEFT JOIN \n    project_passwords proj ON LOWER(TRIM(p.password)) = proj.password  -- Дополнительное соединение для категории \"Проект\"\nWHERE \n    p.password IS NOT NULL\n    AND p.utmsource = 'zakupka'  -- Фильтр по источнику лида\n    AND s.category IS NOT NULL\n    AND p.pipeline_id = 5987164 -- Клиенты в работе\nGROUP BY p.creation_date, p.crm_id, p.password, p.qual, p.booking_event, proj.password\nORDER BY \n    p.creation_date DESC  -- Сортировка по убыванию даты создания"
          }
        }
      ],
