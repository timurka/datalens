        "id": "febacc21-31c1-11f1-8a9b-89e81b293b66",
        "parameter_hash": "7b52123ce906a6cd",
        "connection_id": "qtp2vi8ns03ka",
        "title": "SQL",
        "managed_by": "user",
        "index_info_set": null,
        "source_type": "PG_SUBSELECT",
        "virtual": false,
        "parameters": {
          "subsql": "SELECT\n    m.lead_id AS \"CRM ID сделки\",\n    lf.created_date AS \"Дата и время создания сделки\",\n    m.lead_user_name AS \"Брокер\",\n    COALESCE(NULLIF(BTRIM(t.text), ''), '[без названия]') AS \"Название задачи\",\n    tf.created_date AS \"Дата назначения задачи\",\n    gd_completed.full_date AS \"Дата выполнения задачи\",\n    tf.deadline_date AS \"Дедлайн задачи\",\n    CASE\n        WHEN m.block1_has_overdue_task_on_broker THEN 'Просроченная задача у брокера'\n        WHEN m.block1_has_no_tasks_on_broker THEN 'Нет задачи у брокера'\n        WHEN m.block1_is_healthy_on_broker THEN 'Норма'\n        ELSE 'Требует проверки'\n    END AS \"Итог блока 1\"\nFROM core.amocrm_leads_tasks_block1_metrics m\nLEFT JOIN core.amocrm_leads_facts lf\n  ON lf.account_id = m.account_id\n AND lf.leads_id = m.leads_id\nLEFT JOIN core.amocrm_tasks_facts tf\n  ON tf.account_id = m.account_id\n AND tf.leads_id = m.leads_id\nLEFT JOIN core.amocrm_tasks t\n  ON t.account_id = tf.account_id\n AND t.id = tf.tasks_id\nLEFT JOIN core.general_dates gd_completed\n  ON gd_completed.id = tf.completed_id\nWHERE m.is_in_block1_status_scope = true\n  AND (\n      tf.tasks_id IS NULL\n      OR (\n          COALESCE(t.is_deleted, FALSE) = FALSE\n          AND COALESCE(t.status_code, 0) = 0\n      )\n  )\nORDER BY\n    lf.created_date DESC NULLS LAST,\n    m.lead_id,\n    tf.deadline_date NULLS LAST,\n    t.task_id\n"
        },
        "valid": true
      },
