      "sources": [
        {
          "parameters": {
            "subsql": "-- Определение CTE для пользователей, которые вышли из системы\nWITH leavers_cte AS (\n    -- Выборка информации о ссылках приглашений, количества вышедших и среднего времени жизни в часах\n    SELECT invitelinks,\n           COUNT(*) AS leavers_count,  -- Подсчитываем количество вышедших\n           AVG(EXTRACT(EPOCH FROM (TO_TIMESTAMP(date_left, 'DD.MM.YYYY HH24:MI:SS') - TO_TIMESTAMP(date_join, 'DD.MM.YYYY HH24:MI:SS')))/3600) AS avg_lifetime_hours_leavers -- Расчет среднего времени жизни в часах для тех, кто вышел\n    FROM sheets_report_75096\n    WHERE date_left IS NOT NULL -- Условие на наличие даты выхода\n    GROUP BY invitelinks -- Группировка по ссылкам приглашений\n),\n-- Определение CTE для всех вступивших пользователей\njoiners_cte AS (\n    -- Выборка информации о ссылках приглашений и количества всех вступивших\n    SELECT invitelinks,\n           COUNT(*) AS joiners_count,  -- Подсчитываем общее количество вступивших\n           AVG(EXTRACT(EPOCH FROM (CASE WHEN date_left IS NULL THEN CURRENT_TIMESTAMP ELSE date_left END - date_join))/3600) AS avg_lifetime_hours_joiners -- Расчет среднего времени жизни в часах для всех вступивших, независимо от их текущего статуса\n    FROM zakupki_users_join\n    WHERE date_join IS NOT NULL -- Учитываем только тех, кто присоединился\n    GROUP BY invitelinks -- Группировка по ссылках приглашений\n)\n-- Основной запрос для вывода данных о закупках и расчета средних значений\nSELECT z.date,\n       z.channel_name,\n       z.channel_link,\n       z.cost,\n       z.followers_uae,\n       z.invitelinks_uae,\n       zi.category,\n       COALESCE(jc.joiners_count, 0) AS joiners_count,  -- Замена NULL на 0 для количества вступивших\n       COALESCE(lc.leavers_count, 0) AS leavers_count,  -- Замена NULL на 0 для количества вышедших\n       CASE\n           WHEN COALESCE(lc.leavers_count + jc.joiners_count, 0) > 0 THEN  -- Если есть данные по пользователям\n               ROUND(\n                   ((COALESCE(lc.avg_lifetime_hours_leavers * lc.leavers_count, 0) + COALESCE(jc.avg_lifetime_hours_joiners * jc.joiners_count, 0)) \n                   / (lc.leavers_count + jc.joiners_count)) / 24,  -- Расчет взвешенного среднего лайфтайма в днях\n                   2\n               )\n           ELSE \n               ROUND(COALESCE(jc.avg_lifetime_hours_joiners, 0) / 24, 2) -- Если нет вышедших, используем данные по всем вступившим\n       END AS avg_lifetime_days,\n       CASE \n           WHEN COALESCE(jc.joiners_count, 0) > 0 THEN \n               ROUND((COALESCE(lc.leavers_count, 0)::DECIMAL / COALESCE(jc.joiners_count, 0)) * 100, 2)  -- Расчет процента оттока\n           ELSE 0\n       END AS churn_rate_percentage\nFROM zakupki z\nLEFT JOIN webhook_zakupki_channels_info zi ON z.channel_link = zi.channel_url  -- Присоединение дополнительной информации о каналах\nLEFT JOIN leavers_cte lc ON z.invitelinks_uae = lc.invitelinks  -- Присоединение данных о вышедших\nLEFT JOIN joiners_cte jc ON z.invitelinks_uae = jc.invitelinks  -- Присоединение данных о всех вступивших\nWHERE z.city LIKE '%ОАЭ%'  -- Фильтрация данных по городу\nORDER BY z.date DESC  -- Сортировка результатов по убыванию даты"
          },
