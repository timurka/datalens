      "sources": [
        {
          "index_info_set": null,
          "parameters": {
            "subsql": "WITH combined_sheets AS (\n  -- Объединяем данные из двух таблиц отчётов о пользователях\n  SELECT user_id, date_join, invitelinks, date_left, username, name\n  FROM sheets_report_75329\n  UNION ALL\n  SELECT user_id, date_join, invitelinks, date_left, username, name\n  FROM sheets_report_75605\n),\ncombined_leads AS (\n  -- Объединяем данные из двух таблиц по лидам с унификацией полей и учётом разных имен полей\n  SELECT leads_id, creation_date_time, date_qual, booking_event, qual, price, deal_amount, password, priority, utmsource\n  FROM perfomance_all_leads\n  WHERE password IS NOT NULL -- Фильтруем строки с неопределёнными паролями\n  UNION ALL\n  SELECT lead_id AS leads_id,\n         creation_date AS creation_date_time,\n         qualification_date AS date_qual,\n         is_booked AS booking_event,\n         is_qualified AS qual,\n         budget_usd AS price,\n         NULL AS deal_amount, -- нет аналога в msc_\n         password,\n         priority,\n         utm_source AS utmsource -- Приведение имени поля к общему виду\n  FROM msc_perfomance_all_leads\n  WHERE password IS NOT NULL -- Фильтруем строки с неопределёнными паролями\n)\n\nSELECT lf.contacts_id,\n       COUNT(p.leads_id) AS leads, -- Количество лидов на контакт\n       MAX(ct.telegram_id) AS telegram_id,\n       MAX(uj.date_join) AS date_join,\n       MAX(p.leads_id) AS leads_id,\n       MAX(p.creation_date_time) AS creation_date_time,\n       MAX(p.date_qual) AS date_qual,\n       SUM(p.qual) AS sum_qual, -- Сумма квалифицированных лидов\n       SUM(p.booking_event) AS booking_event,\n       MAX(p.priority) AS priority, -- Максимальный приоритет среди лидов\n       MAX(p.price) AS budget,\n       MAX(p.password) AS password, -- Пароль для сверки доступности\n       MIN(cs.name) AS name,\n       MIN(cs.phone) AS phone,\n       MAX(z.date) AS zakupki_date,\n       MAX(z.channel_name) AS channel_name,\n       MAX(z.channel_link) AS channel_link,\n       MAX(z.cost) AS cost,\n       MAX(uj.invitelinks) AS invitelinks,\n       MAX(tc.category) AS category,\n       MAX(ct.geo) AS geo\n  FROM combined_leads p\n  LEFT JOIN amocrm_leads_facts lf ON lf.leads_id = p.leads_id\n  LEFT JOIN amocrm_contacts cs ON cs.id = lf.contacts_id\n  LEFT JOIN sheets_report_75606 ct ON CAST(ct.contacts_id AS INTEGER) = lf.contacts_id\n  LEFT JOIN combined_sheets uj ON uj.user_id = ct.telegram_id\n  LEFT JOIN zakupki z ON LOWER(TRIM(\n    COALESCE(\n        CASE \n            WHEN ct.geo = 'ОАЭ' THEN z.invitelinks_uae\n            WHEN ct.geo = 'Москва' THEN z.invitelinks_msc\n        END,\n        CASE \n            WHEN ct.geo = 'Москва' THEN z.invitelinks_uae\n            WHEN ct.geo = 'ОАЭ' THEN z.invitelinks_msc\n        END,\n        z.invitelinks\n    )\n  )) = LOWER(TRIM(uj.invitelinks))\n  LEFT JOIN webhook_zakupki_channels_info tc ON tc.channel_url = z.channel_link\n  WHERE p.utmsource = 'zakupka' -- Фильтрация по источнику\n    AND p.qual = 1\n    AND cs.phone IS NOT NULL\n    AND uj.date_join IS NOT NULL\n  GROUP BY lf.contacts_id\n  ORDER BY MAX(p.creation_date_time) DESC"
          },
          "virtual": false,
