          ],
          "parameter_hash": "56707bc64af2335a",
          "title": "SQL",
          "virtual": false,
          "managed_by": "user",
          "parameters": {
            "subsql": "WITH attr AS (\n  SELECT leads_id, \n         account_id,\n         MAX(CASE WHEN attribute_id IN ('1000521', '1001915') THEN value END) AS formname,\n         MAX(CASE WHEN attribute_id IN ('999421') THEN value END) AS formid,\n         MAX(CASE WHEN attribute_id IN ('811717') THEN value END) AS referrer,\n         MAX(CASE WHEN attribute_id IN ('811721') THEN value END) AS list,\n         MAX(CASE WHEN attribute_id IN ('811711') THEN value END) AS utm_term\n  FROM amocrm_leads_attributes \n  GROUP BY leads_id,\n           account_id\n)\n\nSELECT creation_date_time,\n       creation_date,\n       crm_id, \n       utmsource,\n       utm_campaign,\n       utm_medium,\n       a.utm_term,\n       c.name,\n       CASE \n         WHEN c.email IS NOT NULL THEN \n           LEFT(c.email, LENGTH(SPLIT_PART(c.email, '@', 1)) - 2)\n           || '*' || \n           SUBSTRING(c.email FROM POSITION('@' IN c.email))\n         ELSE NULL \n       END AS email,\n       a.formname,\n       a.formid,\n       a.referrer,\n       CASE \n         WHEN a.referrer IS NOT NULL THEN \n           REPLACE(\n             SUBSTRING(a.referrer FROM 1 FOR POSITION('?' IN a.referrer || '?') - 1),\n             'https://buroneg.com/', \n             ''\n           )\n         ELSE '(нет страницы)'\n       END AS webpage,\n       a.list\n       \nFROM perfomance_all_leads p\nLEFT JOIN amocrm_contacts c ON c.id = p.contacts_id AND p.account_id = c.account_id\nLEFT JOIN attr a ON a.leads_id = p.leads_id AND p.account_id = a.account_id\nWHERE pipeline_id = '6605182'\n      AND status_id = 143\n      AND c.email IS NOT NULL\nORDER BY creation_date_time DESC"
          },
          "connection_id": "bpds0nslojo40"
        }
      ],
