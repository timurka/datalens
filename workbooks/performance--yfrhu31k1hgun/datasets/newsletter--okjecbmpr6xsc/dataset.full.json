        "source_type": "PG_SUBSELECT",
        "index_info_set": null,
        "parameters": {
          "subsql": "SELECT\n        pal.leads_id,\n        lt.name AS tag,\n        TO_DATE(RIGHT('0' || SUBSTRING(lt.name FROM 10), 6), 'DDMMYY') AS date,\n        ROW_NUMBER() OVER (PARTITION BY pal.leads_id ORDER BY TO_DATE(RIGHT('0' || SUBSTRING(lt.name FROM 10), 6), 'DDMMYY') DESC) AS rn,\n        pipeline_id,\n        qual,\n        booking_event\n    FROM \n        perfomance_all_leads pal\n    JOIN \n        amocrm_leads_tags lt ON pal.leads_id = lt.leads_id\n    WHERE \n        pal.pipeline_id = 5987164 AND\n        pal.newsletter AND\n        lt.name LIKE 'рассылка_%'"
        }
      },
