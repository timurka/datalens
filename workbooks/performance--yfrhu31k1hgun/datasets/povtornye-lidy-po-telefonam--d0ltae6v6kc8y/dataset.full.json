          "subsql": "WITH all_leads_with_phones AS (\n    -- Выбираем ВСЕ лиды и присоединяем их телефоны для корректного расчета повторности\n    SELECT\n        p.creation_date_time,\n        p.creation_date,\n        p.geo,\n        p.qual,\n        p.crm_id,\n        p.account_id,\n        p.pipeline_id,\n        p.broker_pipeline,\n        p.pipeline,\n        p.contacts_amo_id,\n        p.utmsource\n    FROM mart.perfomance_all_leads p\n),\nlead_phones AS (\n    -- Присоединяем телефоны к лидам и разворачиваем номера, указанные через запятую\n    SELECT\n        lb.creation_date_time,\n        lb.creation_date,\n        lb.geo,\n        lb.qual,\n        lb.crm_id,\n        lb.pipeline_id,\n        lb.broker_pipeline,\n        lb.pipeline,\n        lb.utmsource,\n        trim(p.phone_number) AS phone_number\n    FROM all_leads_with_phones lb\n    JOIN core.amocrm_contacts ac ON lb.account_id = ac.account_id AND lb.contacts_amo_id = ac.contact_id\n    CROSS JOIN LATERAL unnest(string_to_array(ac.phone, ',')) AS p(phone_number)\n    WHERE ac.phone IS NOT NULL AND ac.phone != ''\n),\nranked_leads AS (\n    -- Ранжируем ВСЕ лиды по времени для каждого телефона\n    SELECT\n        crm_id,\n        phone_number,\n        geo,\n        pipeline_id,\n        broker_pipeline,\n        pipeline,\n        creation_date_time,\n        creation_date,\n        qual,\n        utmsource,\n        ROW_NUMBER() OVER(PARTITION BY phone_number ORDER BY creation_date_time) as rn\n    FROM lead_phones\n)\n-- Формируем итоговый датасет для BI, фильтруя только нужные нам лиды из 2025 года\nSELECT\n    crm_id,\n    phone_number,\n    geo,\n    creation_date,  \n    pipeline_id,\n    broker_pipeline,\n    pipeline,\n    utmsource,\n    creation_date_time,\n    1 AS lead, -- Каждый лид в этой выборке является лидом\n    qual, -- 1 если квал, 0 если нет\n    CASE WHEN rn > 1 THEN 1 ELSE 0 END AS is_repeat_lead,\n    CASE WHEN rn > 1 AND qual = 1 THEN 1 ELSE 0 END AS is_repeat_qual\nFROM ranked_leads\nWHERE  -- utmsource = 'zakupka'\n  --AND EXTRACT(YEAR FROM creation_date_time) = 2025\n    geo IS NOT NULL\nORDER BY phone_number, creation_date_time"
        },
