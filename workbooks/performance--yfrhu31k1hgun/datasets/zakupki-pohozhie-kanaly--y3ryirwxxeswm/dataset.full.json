        "parameter_hash": "81834d01b56bddcc",
        "virtual": false,
        "parameters": {
          "subsql": "WITH mention_counts AS (\n    SELECT \n        channel_link,\n        COUNT(*) AS mention_count,\n        SUM(followers_uae) AS sum_uae\n    FROM \n        zakupki\n    GROUP BY \n        channel_link\n)\nSELECT\n    zsc.*,\n    CONCAT('https://t.me/', zsc.username) AS URL,\n    mc.mention_count,\n    mc.sum_uae,\n    zi.category\nFROM\n    zakupki_similar_channels zsc\nLEFT JOIN\n    mention_counts mc ON CONCAT('https://t.me/', zsc.username) = mc.channel_link\nLEFT JOIN\n    webhook_zakupki_channels_info zi ON CONCAT('https://t.me/', zsc.username) = zi.channel_url"
        },
