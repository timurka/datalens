          "id": "36b9e401-411b-11f0-9736-5f15703cd96a",
          "parameter_hash": "9c41ac2cb359a05a",
          "connection_id": "bpds0nslojo40",
          "title": "SQL",
          "managed_by": "user",
          "index_info_set": null,
          "source_type": "PG_SUBSELECT",
          "virtual": false,
          "parameters": {
            "subsql": "-- Медиаплан: сводный отчет план/факт по ключевым метрикам (бюджет, лиды, квалы, брони, выручка) по географиям\n\nWITH plan_data AS (\n    SELECT \n        mesjats::date as month,\n        LOWER(TRIM(napravlenie)) as join_geo, \n        MIN(TRIM(napravlenie)) as display_geo_plan, \n        SUM(CASE WHEN bjudzhet_plan ~ '^\\d+(\\.\\d+)?$' THEN bjudzhet_plan::numeric ELSE NULL END) AS plan_budget,\n        SUM(CASE WHEN leads_plan ~ '^\\d+$' THEN leads_plan::integer ELSE NULL END) AS plan_leads,\n        SUM(CASE WHEN qual_leads_plan ~ '^\\d+$' THEN qual_leads_plan::integer ELSE NULL END) AS plan_quals,\n        SUM(CASE WHEN broni_plan ~ '^\\d+$' THEN broni_plan::integer ELSE NULL END) AS plan_booking,\n        SUM(CASE WHEN vyruchka_plan ~ '^\\d+(\\.\\d+)?$' THEN vyruchka_plan::numeric ELSE NULL END) AS plan_revenue\n    FROM sheets_report_82576\n    WHERE TRIM(napravlenie) IS NOT NULL AND TRIM(napravlenie) != ''\n    GROUP BY mesjats::date, LOWER(TRIM(napravlenie))\n),\n\nrevenue_data AS (\n    -- Свод выручки по гео из отдельных таблиц с учётом конвертации валют\n    -- ОАЭ: выручка в дирхамах, переводим в доллары по фиксированному курсу 3.67\n    SELECT date_trunc('month', date::date)::date AS month,\n           lower('ОАЭ') AS join_geo,\n           SUM((revenue::numeric) / 3.67) AS revenue_fact\n    FROM sheets_report_83262\n    WHERE date IS NOT NULL\n    GROUP BY 1\n\n    UNION ALL\n\n    SELECT date_trunc('month', date::date)::date AS month,\n           lower('Москва') AS join_geo,\n           SUM(revenue::numeric) AS revenue_fact\n    FROM sheets_report_83263\n    WHERE date IS NOT NULL\n    GROUP BY 1\n\n    UNION ALL\n\n    -- Грузия: выручка уже в долларах\n    SELECT date_trunc('month', date::date)::date AS month,\n           lower('Грузия') AS join_geo,\n           SUM(revenue::numeric) AS revenue_fact\n    FROM sheets_report_83266\n    WHERE date IS NOT NULL\n    GROUP BY 1\n\n    UNION ALL\n\n    -- Бали: выручка в долларах\n    SELECT date_trunc('month', date::date)::date AS month,\n           lower('Бали') AS join_geo,\n           SUM(revenue::numeric) AS revenue_fact\n    FROM sheets_report_83264\n    WHERE date IS NOT NULL\n    GROUP BY 1\n\n    UNION ALL\n\n    -- Таиланд: выручка в долларах\n    SELECT date_trunc('month', date::date)::date AS month,\n           lower('Таиланд') AS join_geo,\n           SUM(revenue::numeric) AS revenue_fact\n    FROM sheets_report_83265\n    WHERE date IS NOT NULL\n    GROUP BY 1\n),\n\nfact_data AS (\n    SELECT \n        perf.month, \n        perf.join_geo, \n        perf.display_geo_fact, \n        perf.budget_fact,\n        rev.revenue_fact,\n        perf.leads_fact,\n        perf.quals_fact,\n        perf.bookings_fact\n    FROM (\n        SELECT \n            month, \n            LOWER(TRIM(geo)) AS join_geo, \n            geo AS display_geo_fact, \n            SUM(cost_usd) AS budget_fact,\n            SUM(leads) AS leads_fact,\n            SUM(quals) AS quals_fact,\n            SUM(bookings) AS bookings_fact\n        FROM perfomance_svodny_actions \n        WHERE TRIM(geo) IS NOT NULL AND TRIM(geo) != ''\n        GROUP BY month, LOWER(TRIM(geo)), geo\n    ) perf\n    LEFT JOIN revenue_data rev ON rev.month = perf.month AND rev.join_geo = perf.join_geo\n),\n\nbase AS (                      -- ❶ «Сырые» данные без вычисленных метрик\n    SELECT\n        COALESCE(p.month, f.month)                 AS report_month,\n        CASE \n            WHEN COALESCE(p.plan_budget,0)=0 THEN 'Прочее'\n            ELSE COALESCE(p.display_geo_plan, f.display_geo_fact)\n        END AS report_geo,\n        p.plan_budget      AS budget_plan,\n        f.budget_fact      AS budget_fact,\n        p.plan_revenue     AS revenue_plan,\n        f.revenue_fact     AS revenue_fact,\n        p.plan_leads       AS leads_plan,\n        f.leads_fact       AS leads_fact,\n        p.plan_quals       AS quals_plan,\n        f.quals_fact       AS quals_fact,\n        p.plan_booking     AS bookings_plan,\n        f.bookings_fact    AS bookings_fact\n    FROM plan_data  p\n    FULL JOIN fact_data f\n      ON p.month = f.month  AND p.join_geo = f.join_geo\n),\n\nagg AS (                       -- ❷ агрегируем гео + добавляем «итого»\n    SELECT\n        report_month,\n        COALESCE(report_geo, 'Итого')              AS report_geo,\n\n        /* ----------- агрегированные суммы ------------ */\n        SUM(budget_plan)        AS budget_plan,\n        SUM(budget_fact)        AS budget_fact,\n        SUM(revenue_plan)       AS revenue_plan,\n        SUM(revenue_fact)       AS revenue_fact,\n        SUM(leads_plan)         AS leads_plan,\n        SUM(leads_fact)         AS leads_fact,\n        SUM(quals_plan)         AS quals_plan,\n        SUM(quals_fact)         AS quals_fact,\n        SUM(bookings_plan)      AS bookings_plan,\n        SUM(bookings_fact)      AS bookings_fact\n\n    FROM base\n    GROUP BY GROUPING SETS            -- строка-гео + строка «итого»\n           ((report_month, report_geo),\n            (report_month))           -- ② ← даёт NULL вместо geo\n)\n\nSELECT\n    report_month,\n    report_geo,\n\n    /* ----------- суммы ----------- */\n    budget_plan , budget_fact ,\n    revenue_plan, revenue_fact,\n    leads_plan  , leads_fact  ,\n    quals_plan  , quals_fact  ,\n    bookings_plan, bookings_fact,\n\n    /* ----------- CPL / AOV / ROMI ----------- */\n    CASE WHEN leads_plan   > 0 THEN ROUND(budget_plan  / leads_plan  ,2) END AS cpl_plan,\n    CASE WHEN leads_fact   > 0 THEN ROUND(budget_fact  / leads_fact  ,2) END AS cpl_fact,\n\n    CASE WHEN bookings_plan> 0 THEN ROUND(budget_plan  / bookings_plan,2) END AS cpa_plan,\n    CASE WHEN bookings_fact> 0 THEN ROUND(budget_fact  / bookings_fact,2) END AS cpa_fact,\n\n    CASE WHEN bookings_plan> 0 THEN ROUND(revenue_plan / bookings_plan,2) END AS aov_plan,\n    CASE WHEN bookings_fact> 0 THEN ROUND(revenue_fact / bookings_fact,2) END AS aov_fact,\n\n    CASE WHEN budget_plan  > 0 THEN ROUND((revenue_plan - budget_plan)/budget_plan ,2) END AS romi_plan,\n    CASE WHEN budget_fact  > 0 THEN ROUND((revenue_fact - budget_fact)/budget_fact ,2) END AS romi_fact,\n\n    /* ----------- Δ-метрики (как в DataLens) ----------- */\n    CASE WHEN budget_plan  > 0 THEN ROUND((budget_plan  - budget_fact)/budget_plan ,2) END AS delta_budget,\n    CASE WHEN revenue_plan > 0 THEN ROUND((revenue_fact - revenue_plan)/revenue_plan,2) END AS delta_revenue,\n    CASE WHEN leads_plan   > 0 THEN ROUND((leads_fact   - leads_plan )/leads_plan ,2) END AS delta_leads,\n    CASE WHEN bookings_plan> 0 THEN ROUND((bookings_fact- bookings_plan)/bookings_plan,2) END AS delta_bookings,\n\n    CASE WHEN budget_plan  >0 AND leads_plan  >0 AND leads_fact>0\n         THEN ROUND( (budget_plan/leads_plan - budget_fact/leads_fact)\n                     /(budget_plan/leads_plan) ,2) END                AS delta_cpl,\n\n    CASE WHEN bookings_plan>0 AND bookings_fact>0\n         THEN ROUND( (revenue_fact/bookings_fact - revenue_plan/bookings_plan)\n                     /(revenue_plan/bookings_plan) ,2) END            AS delta_aov,\n\n    CASE WHEN budget_plan>0 AND budget_fact>0\n         THEN ROUND( ((revenue_fact-budget_fact)/budget_fact -\n                      (revenue_plan-budget_plan)/budget_plan)\n                     / ((revenue_plan-budget_plan)/budget_plan) ,2) END AS delta_romi,\n\n    CASE WHEN quals_plan>0 THEN ROUND((quals_fact-quals_plan)/quals_plan,2) END AS delta_quals\n\nFROM agg\nORDER BY\n    report_month DESC,\n    CASE WHEN report_geo='Итого' THEN 1 ELSE 0 END,  -- сначала строки-гео, внизу «итого»\n    report_geo"
          },
          "valid": true
        }
      ],
