      "sources": [
        {
          "parameters": {
            "subsql": "WITH aggregated_data AS (\n    SELECT\n        TO_DATE(TO_CHAR(z.date, 'MM.YYYY'), 'MM.YYYY') AS month_year,  -- Преобразуем в дату сразу здесь\n        SUM(CASE WHEN z.city LIKE '%Москва%' THEN z.followers_msc ELSE 0 END) AS total_followers_msc,\n        SUM(CASE WHEN z.city LIKE '%ОАЭ%' THEN z.followers_uae ELSE 0 END) AS total_followers_uae,\n        SUM(CASE WHEN z.city LIKE '%Бали%' THEN z.followers_bali ELSE 0 END) AS total_followers_bali,\n        SUM(CASE \n            WHEN z.city LIKE '%Москва%' THEN \n                z.cost / CASE WHEN strpos(z.city, '+') > 0 THEN 2 ELSE 1 END\n            ELSE 0 \n            END) AS total_cost_msc,\n        SUM(CASE \n            WHEN z.city LIKE '%ОАЭ%' THEN \n                z.cost / CASE WHEN strpos(z.city, '+') > 0 THEN 2 ELSE 1 END\n            ELSE 0 \n            END) AS total_cost_uae,\n        SUM(CASE \n            WHEN z.city LIKE '%Бали%' THEN \n                z.cost / CASE WHEN strpos(z.city, '+') > 0 THEN 2 ELSE 1 END\n            ELSE 0 \n            END) AS total_cost_bali,\n        COUNT(CASE WHEN z.city LIKE '%Москва%' THEN 1 ELSE NULL END) AS msc_placements_count,\n        COUNT(CASE WHEN z.city LIKE '%ОАЭ%' THEN 1 ELSE NULL END) AS uae_placements_count,\n        COUNT(CASE WHEN z.city LIKE '%Бали%' THEN 1 ELSE NULL END) AS bali_placements_count\n    FROM\n        zakupki z\n    GROUP BY\n        TO_DATE(TO_CHAR(z.date, 'MM.YYYY'), 'MM.YYYY')\n),\ncpf_calculation AS (\n    SELECT\n        month_year,\n        total_followers_msc,\n        total_followers_uae,\n        total_followers_bali,\n        total_cost_msc,\n        total_cost_uae,\n        total_cost_bali,\n        CASE \n            WHEN total_followers_msc > 0 THEN\n                total_cost_msc / total_followers_msc\n            ELSE NULL \n        END AS CPF_msc,\n        CASE \n            WHEN total_followers_uae > 0 THEN\n                total_cost_uae / total_followers_uae\n            ELSE NULL \n        END AS CPF_uae,\n        CASE \n            WHEN total_followers_bali > 0 THEN\n                total_cost_bali / total_followers_bali\n            ELSE NULL \n        END AS CPF_bali,\n        msc_placements_count,\n        uae_placements_count,\n        bali_placements_count\n    FROM\n        aggregated_data\n)\nSELECT\n    month_year, \n    total_followers_msc,\n    total_followers_uae,\n    total_followers_bali,\n    total_cost_msc,\n    total_cost_uae,\n    total_cost_bali,\n    CPF_msc,\n    CPF_uae,\n    CPF_bali,\n    msc_placements_count,\n    uae_placements_count,\n    bali_placements_count\nFROM\n    cpf_calculation\nORDER BY\n    month_year DESC\n"
          },
          "source_type": "PG_SUBSELECT",
