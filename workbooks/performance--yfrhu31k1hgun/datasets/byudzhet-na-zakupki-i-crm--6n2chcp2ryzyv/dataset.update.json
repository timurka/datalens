          "parameter_hash": "d4aee51f6430c675",
          "virtual": false,
          "parameters": {
            "subsql": "WITH FilteredLeads AS (\n    -- Фильтруем Автосделки\n    SELECT DISTINCT\n        la.leads_id\n    FROM \n        amocrm_leads_attributes la\n    WHERE \n        -- Общий признак: есть атрибут \"Новый запрос\"\n        la.attribute_id = '944979' AND la.value = 'Новый запрос' \n        AND (\n            -- 1 признак: есть атрибут \"Первичная сделка\"\n            la.leads_id IN (\n                SELECT leads_id FROM amocrm_leads_attributes WHERE attribute_id = '993439'\n            )\n            OR\n            -- Или 2 признак: нет атрибута \"Прошлая причина отказа\"\n            la.leads_id NOT IN (\n                SELECT leads_id FROM amocrm_leads_attributes WHERE attribute_id = '989757'\n            )\n        )\n),\n\nCreatedLeads AS (\n    -- События создания лидов, даты создания и pipeline_id из таблицы событий\n    SELECT\n        le.leads_id,\n        DATE(le.created_at) AS created_date\n    FROM \n        amocrm_leads_events le\n    JOIN amocrm_leads_tags lt ON le.leads_id = lt.leads_id\n    JOIN amocrm_leads l ON le.leads_id = l.id\n    WHERE\n        le.type = 'lead_added' -- Событие создания лида\n        AND lt.tag_id = 161545 -- Тег \"Закупка\"\n        AND l.pipeline_id = 5987164 -- Воронка \"Клиенты в работе\"\n        \n        -- Фильтрует автосделки по двум признакам\n        AND le.leads_id IN (SELECT leads_id FROM FilteredLeads)\n),\n\nQualifiedLeads AS (\n    -- Лиды, которые достигли квалифицированного статуса, проверяя атрибут '978575'\n    SELECT DISTINCT\n        la.leads_id\n    FROM \n        amocrm_leads_attributes la\n    JOIN \n        CreatedLeads cl ON la.leads_id = cl.leads_id\n    WHERE \n        la.attribute_id = '978575' -- Атрибут, указывающий на приоритет\n        AND la.value IN ('A', 'B', 'C') -- Проверяем, что лид имеет приоритет A, B или C\n),\n\nLeadStats AS (\n    -- Статистика по созданным и квалифицированным лидам, сгруппированная по дате\n    SELECT\n        cl.created_date,\n        COUNT(cl.leads_id) AS leads,\n        COUNT(ql.leads_id) AS qleads\n    FROM \n        CreatedLeads cl\n    LEFT JOIN \n        QualifiedLeads ql ON cl.leads_id = ql.leads_id\n    GROUP BY \n        cl.created_date\n),\n\nBudgetStats AS (\n    -- Расчет бюджета на день и фактических расходов, сгруппированный по дате, с добавлением CPL и CRQ\n    SELECT\n        wz.date,\n        (wb.budget / EXTRACT(DAY FROM DATE_TRUNC('MONTH', wz.date + INTERVAL '1 MONTH') - INTERVAL '1 DAY')) AS plan_per_day,\n        -- Считаем расходы только для ОАЭ\n        SUM(\n            CASE\n                WHEN wz.city = 'ОАЭ' THEN wz.cost\n                WHEN wz.city = 'ОАЭ+Москва' THEN wz.cost / 2\n                WHEN wz.city = 'ОАЭ+Бали' THEN wz.cost / 2\n                ELSE 0 -- Для других городов расходы не учитываются\n            END\n        ) AS fact,\n        wb.cpl, -- Стоимость за лид\n        wb.crq,  -- Конверсия в квалифицированный лид\n        wb.cpf, -- План по CPF\n        SUM(wz.followers_uae) AS total_followers_uae -- Суммарное количество подписчиков ОАЭ за день \n    FROM\n        zakupki wz\n    JOIN\n        zakupki_budget wb ON wz.date BETWEEN wb.start_date AND wb.end_date\n    WHERE\n        wz.date <= CURRENT_DATE -- До текущей даты\n        AND wz.test = false -- Не включаем эксперимент. закупки\n    GROUP BY\n        wz.date, wb.budget, wb.cpl, wb.crq, wb.cpf\n)\n\n-- Основной запрос соединяет статистику бюджета с данными о лидах\nSELECT\n    bs.date,\n    bs.plan_per_day,\n    bs.fact,\n    bs.total_followers_uae,\n    bs.cpl,\n    bs.crq,\n    bs.cpf,\n    COALESCE(ls.leads, 0) AS leads, -- Если нет лидов, возвращаем 0\n    COALESCE(ls.qleads, 0) AS qleads -- Если нет квалифицированных лидов, возвращаем 0\n    \nFROM \n    BudgetStats bs\nLEFT JOIN \n    -- Соединяем по дате бюджета\n    LeadStats ls ON bs.date = ls.created_date \nORDER BY \n    bs.date"
          },
