          "formula": "CASE [type]\n    WHEN 'reg' THEN \"Регистрация\"\n    WHEN 'visit' THEN \"Зашли на вебинар\"\n    WHEN 'finish' THEN \"Заявка на запись\"\n    WHEN 'interest' THEN \"Интерес к подбору\"\n    WHEN 'click' THEN \"Интерес к подбору\"\n    WHEN 'form' THEN \"Отправили анкету\"\n    WHEN 'guide' THEN \"Получили гайд\"\n    WHEN 'zoom' THEN \"Заявка на zoom\"\nEND",
