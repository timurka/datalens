          "parameter_hash": "1153785c2ebf7ca8",
          "virtual": false,
          "parameters": {
            "subsql": "-- Помесячный отчет по лидам из RED\n\n-- CTE для дополнительной выборки по pipeline_id = '5987164'\n      WITH additional_data AS (\n          SELECT \n              *\n          FROM perfomance_all_leads\n          WHERE pipeline_id = '5987164'\n      ),\n\n      topipeline AS ( -- Передано в воронку\n        SELECT \n            leads_id,\n            MAX(CASE WHEN attribute_id = '1012385' THEN value END) AS pipeline\n        FROM amocrm_leads_attributes\n        WHERE attribute_id IN ('1012385')\n          GROUP BY leads_id\n      ),\n\n      meets AS (\n        SELECT leads_id\n        FROM amocrm_leads_events\n        WHERE type = 'lead_status_changed' \n\t\t\t  AND value_after LIKE '%5987164%' \n\t\t\t  AND value_after LIKE '%58223142%'\n      ),\n\n      -- CTE для атрибутов лидов\n      lead_attributes AS (\n          SELECT leads_id, \n                 CAST(value AS BIGINT) AS external_crm_id -- ID оригинала лида\n          FROM amocrm_leads_attributes\n          WHERE attribute_id = '1004725'\n      ),\n      \n      -- Из воронки \"Валидация. База\"\n      other_pipeline_data AS (\n          SELECT l.id,\n                 l.pipeline_id,\n                 l.status_id,\n                 a.external_crm_id,\n                 gd.full_date AS creation_date_time\n          FROM amocrm_leads l\n          LEFT JOIN amocrm_leads_tags t ON l.id = t.leads_id\n          LEFT JOIN lead_attributes a ON l.id = a.leads_id\n          LEFT JOIN amocrm_leads_facts lf ON l.id = lf.leads_id\n          LEFT JOIN general_dates gd ON lf.created_id = gd.id\n          WHERE l.pipeline_id = '8053810'\n                AND t.name = 'RED'\n                AND a.external_crm_id = l.lead_id\n      ),\n\n      expenses AS (\n          SELECT \n              date_trunc('month', date)::date AS expense_month,\n              SUM(amount) AS monthly_expense\n          FROM (\n              VALUES \n                  ('2024-06-21'::date, 19500),\n                  ('2024-09-05'::date, 19500),\n                  ('2024-10-04'::date, 20000),\n                  ('2024-10-18'::date, 20000)\n          ) AS expenses(date, amount)\n          GROUP BY date_trunc('month', date)::date\n      )\n\n      -- Основной запрос\n      SELECT \n          p.creation_date_time,\n          e.monthly_expense, -- Общая сумма расходов за месяц\n          p.crm_id AS v_id,\n          ad.crm_id AS b_id,\n          p.status_id AS v_status_id,\n          ad.status_id AS b_status_id,\n          ad.contact_in,\n          ad.qual,\n          ad.priority,\n          ad.booking_event,\n          ad.deal_amount,\n          p.pipeline_id,\n          m.leads_id AS meet_id,\n          CASE WHEN p.crm_id IS NOT NULL \n                    AND ad.crm_id IS NULL \n                    AND p.pipeline_id = '7309478'\n                    AND p.status_id != 142 \n                    AND p.status_id != 143 \n               THEN 1 ELSE 0 END AS v_in_progress\n\n      FROM (\n          SELECT -- Валидация и брокеры\n              creation_date_time,\n              crm_id,\n              status_id,\n              external_crm_id,\n              leads_id,\n              pipeline_id\n          FROM perfomance_all_leads\n          WHERE pipeline_id = '7309478'\n          UNION ALL\n          SELECT -- Валидация. База\n              creation_date_time,\n              id AS crm_id,\n              status_id,\n              external_crm_id,\n              id AS leads_id,\n              pipeline_id\n          FROM other_pipeline_data\n      ) p\n      LEFT JOIN amocrm_leads_tags t ON p.leads_id = t.leads_id\n      LEFT JOIN additional_data ad ON p.external_crm_id = ad.external_crm_id\n      LEFT JOIN topipeline tp ON p.leads_id = tp.leads_id\n      LEFT JOIN meets m ON ad.leads_id = m.leads_id\n      LEFT JOIN expenses e ON date_trunc('month', p.creation_date_time)::date = e.expense_month\n      WHERE t.name = 'RED'\n      ORDER BY p.creation_date_time"
          },
