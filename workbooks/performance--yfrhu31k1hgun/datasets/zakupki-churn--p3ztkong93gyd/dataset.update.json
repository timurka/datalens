          "source_type": "PG_SUBSELECT",
          "virtual": false,
          "parameters": {
            "subsql": "SELECT \n    s.user_id,\n    s.name,\n    s.username,\n    DATE(s.date_join) AS date_join,\n    DATE(s.date_left) AS date_left,\n    s.invitelinks,\n    z.invitelinks AS z_invitelinks,\n    z.invitelinks_uae AS z_invitelinks_uae,\n    z.invitelinks_msc AS z_invitelinks_msc,\n    z.channel_name,\n    z.channel_link,\n    z.cost,\n    z.followers_msc,\n    z.followers_uae,\n    z.post,\n    z.date AS z_date  -- Дата закупки\nFROM sheets_report_75096 s\nLEFT JOIN zakupki z ON z.invitelinks = s.invitelinks\n                   OR z.invitelinks_uae = s.invitelinks\n                   OR z.invitelinks_msc = s.invitelinks"
          },
          "valid": true
