          "parameter_hash": "468fed3fd158c552",
          "title": "SQL",
          "virtual": false,
          "managed_by": "user",
          "parameters": {
            "subsql": "WITH events AS (\n    -- Регистрации\n    SELECT \n        creation_date::date as event_date,\n        'Регистрация' as event_type,\n        COUNT(*) as event_count,\n        webinar,\n        utmsource,\n        geo,\n        NULL as priority,\n        CAST(NULL AS NUMERIC) as deal_amount\n    FROM webinars\n    WHERE reg = 1\n    GROUP BY creation_date::date, webinar, utmsource, geo\n\n    UNION ALL\n\n    -- Визиты\n    SELECT \n        creation_date::date,\n        'Визит' as event_type,\n        COUNT(*) as event_count,\n        webinar,\n        utmsource,\n        geo,\n        NULL as priority,\n        CAST(NULL AS NUMERIC) as deal_amount\n    FROM webinars\n    WHERE visit = 1\n    GROUP BY creation_date::date, webinar, utmsource, geo\n\n    UNION ALL\n\n    -- Лиды\n    SELECT \n        creation_date::date,\n        'Лид' as event_type,\n        COUNT(*) as event_count,\n        webinar,\n        utmsource,\n        geo,\n        NULL as priority,\n        CAST(NULL AS NUMERIC) as deal_amount\n    FROM webinars\n    WHERE broker = 1\n    GROUP BY creation_date::date, webinar, utmsource, geo\n\n    UNION ALL\n\n    -- Квалификации\n    SELECT \n        date_qual::date,\n        'Квалификация' as event_type,\n        COUNT(*) as event_count,\n        webinar,\n        utmsource,\n        geo,\n        priority,\n        CAST(NULL AS NUMERIC) as deal_amount\n    FROM webinars\n    WHERE date_qual IS NOT NULL\n          AND qual = 1\n          AND broker = 1\n    GROUP BY date_qual::date, webinar, utmsource, geo, priority\n\n    UNION ALL\n\n    -- Брони\n    SELECT \n        date_booking::date,\n        'Бронь' as event_type,\n        COUNT(*) as event_count,\n        webinar,\n        utmsource,\n        geo,\n        NULL as priority,\n        deal_amount\n    FROM webinars\n    WHERE date_booking IS NOT NULL\n          AND booking = 1\n          AND broker = 1\n    GROUP BY date_booking::date, webinar, utmsource, geo, deal_amount\n)\n\nSELECT \n    event_date,\n    event_type,\n    event_count,\n    webinar,\n    utmsource,\n    geo,\n    priority,\n    deal_amount,\n    -- Добавляем накопительные итоги по типам событий\n    SUM(event_count) OVER ( \n        PARTITION BY event_type, webinar, utmsource, geo, priority\n        ORDER BY event_date\n    ) as cumulative_count\nFROM events\nWHERE event_date IS NOT NULL\nORDER BY event_date DESC, event_type"
          },
          "connection_id": "bpds0nslojo40"
        }
