    "queryValue": "WITH base AS (\n    SELECT\n        id,\n        geo,\n        utmsource,\n        reason,\n        CASE\n            WHEN creation_date BETWEEN {{reason_date1_from}} AND {{reason_date1_to}}\n                 THEN to_char({{reason_date1_from}}::date, 'DD.MM.YYYY')\n                      || ' - ' ||\n                      to_char({{reason_date1_to}}  ::date, 'DD.MM.YYYY')\n            WHEN creation_date BETWEEN {{reason_date2_from}} AND {{reason_date2_to}}\n                 THEN to_char({{reason_date2_from}}::date, 'DD.MM.YYYY')\n                      || ' - ' ||\n                      to_char({{reason_date2_to}}  ::date, 'DD.MM.YYYY')\n            ELSE NULL\n        END AS period_label\n    FROM public.parent_child_leads\n    WHERE status_id = 143\n\n      -- фильтр по reason\n      AND reason NOT ILIKE 'Передано%'\n      AND reason NOT ILIKE 'Партн%'\n      AND reason NOT ILIKE 'Рефер%'\n      AND reason NOT IN (\n           'Отдел Заботы', 'ХКВ (Архив)', 'Не готовы оплачивать КВ по вторичке',\n           'Трансфер средств', 'Fake lead', 'Family Office',\n           'Not relevant at the moment', 'Postponed to a specific date'\n      )\n\n      -- обязательные пайплайны\n      AND (broker_pipeline = 1 OR valid_pipeline = 1)\n\n      -- динамический фильтр по geo\n      AND ( {{geo}} IS NULL\n            OR {{geo}} = ''\n            OR geo = {{geo}} )\n\n      -- динамический фильтр по utmsource\n      AND ( {{utmsource}} IS NULL\n            OR {{utmsource}} = ''\n            OR utmsource = {{utmsource}} )\n\n      -- широкая «рамка» по датам, чтобы сработал индекс\n      AND creation_date BETWEEN \n            LEAST({{reason_date1_from}}, {{reason_date2_from}})\n        AND GREATEST({{reason_date1_to}},   {{reason_date2_to}})\n)\nSELECT\n    geo,\n    utmsource,\n    reason,\n    period_label,               -- \"01.01.2025 - 03.01.2025\"\n    COUNT(DISTINCT id) AS id_cnt\nFROM base\nWHERE period_label IS NOT NULL\nGROUP BY geo, utmsource, reason, period_label\nORDER BY geo, utmsource, reason, period_label;",
    "queries": [],
