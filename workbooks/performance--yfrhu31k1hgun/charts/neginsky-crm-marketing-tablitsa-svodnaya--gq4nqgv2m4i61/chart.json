          "aggregation_locked": true,
          "virtual": false,
          "guid_formula": "CASE [geo_o6vm]\n    WHEN 'Р‘Р°Р»Рё' THEN 'вЂ‹вЂ‹вЂ‹рџ‡®рџ‡© Р‘Р°Р»Рё'\n    WHEN 'РўР°РёР»Р°РЅРґ' THEN 'вЂ‹вЂ‹вЂ‹вЂ‹рџ‡№рџ‡­ РўР°РёР»Р°РЅРґ'\n    WHEN 'РћРђР­' THEN 'рџ‡¦рџ‡Є РћРђР­'\n    WHEN 'РњРѕСЃРєРІР°' THEN 'вЂ‹вЂ‹рџ‡·рџ‡є РњРѕСЃРєРІР°'\n    WHEN 'РЎРџР±' THEN 'вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹рџЏ›пёЏ РЎРџР±'\n    WHEN 'Р“СЂСѓР·РёСЏ' THEN 'вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹рџ‡¬рџ‡Є Р“СЂСѓР·РёСЏ'\n    WHEN 'РЎРѕС‡Рё' THEN 'вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹рџЏ– РЎРѕС‡Рё'\n    WHEN 'РљРёРїСЂ' THEN 'вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹рџ‡Ёрџ‡ѕ РљРёРїСЂ'\n    WHEN 'РўСѓСЂС†РёСЏ' THEN 'вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹вЂ‹рџ‡№рџ‡· РўСѓСЂС†РёСЏ'\n    ELSE [geo_o6vm]\nEND",
