    "queryValue": "WITH quals AS (\n    -- Количество квалифицированных лидов\n    SELECT \n        DATE(date_qual) as date_qual,\n        pipeline_id,\n        utmsource,\n        COUNT(leads_id) as qualifications\n    FROM perfomance_all_leads\n    WHERE date_qual IS NOT NULL\n        AND (pipeline_id = 5987164 OR pipeline_id = 8650122)\n    GROUP BY DATE(date_qual), pipeline_id, utmsource\n),\nbookings AS (\n    -- Количество броней\n    SELECT \n        DATE(date_booking) as date_booking,\n        pipeline_id,\n        utmsource,\n        COUNT(leads_id) as bookings\n    FROM perfomance_all_leads\n    WHERE date_booking IS NOT NULL\n        AND (pipeline_id = 5987164 OR pipeline_id = 8650122)\n    GROUP BY DATE(date_booking), pipeline_id, utmsource\n),\nvalidations AS (\n    -- Количество валидаций\n    SELECT \n        DATE(le.created_at) as date_validation,\n        p.pipeline_id,\n        p.utmsource,\n        COUNT(p.leads_id) as validations\n    FROM perfomance_all_leads p\n    JOIN amocrm_leads_events le ON p.leads_id = le.leads_id\n    WHERE le.type = 'lead_status_changed' \n        AND le.value_after LIKE '%7309478%' \n        AND le.value_after LIKE '%142%' -- Ру-воронка\n    GROUP BY DATE(le.created_at), p.pipeline_id, p.utmsource\n)\nSELECT \n    p.creation_date,\n    p.pipeline_id,\n    p.utmsource,\n    COUNT(p.leads_id) as leads,\n    COALESCE(q.qualifications, 0) as quals,\n    COALESCE(b.bookings, 0) as bookings,\n    COALESCE(v.validations, 0) as validations\nFROM perfomance_all_leads p\nLEFT JOIN quals q ON p.creation_date = q.date_qual \n    AND p.pipeline_id = q.pipeline_id \n    AND p.utmsource = q.utmsource\nLEFT JOIN bookings b ON p.creation_date = b.date_booking\n    AND p.pipeline_id = b.pipeline_id \n    AND p.utmsource = b.utmsource\nLEFT JOIN validations v ON p.creation_date = v.date_validation\n    AND p.pipeline_id = v.pipeline_id \n    AND p.utmsource = v.utmsource\nWHERE (\n    (p.pipeline_id = 5987164 AND (p.source_deal IS NULL OR p.source_deal != 'Валидация'))\n    OR p.pipeline_id = 7309478\n    OR p.pipeline_id = 8650122\n)\nGROUP BY p.creation_date, \n         p.pipeline_id,\n         p.utmsource,\n         q.qualifications,\n         b.bookings,\n         v.validations\nORDER BY p.creation_date DESC",
