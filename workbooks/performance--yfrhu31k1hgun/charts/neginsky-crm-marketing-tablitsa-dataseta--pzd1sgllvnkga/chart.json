          "formula": "CASE [geo]\n    WHEN 'Бали' THEN '​​​🇮🇩 Бали'\n    WHEN 'Таиланд' THEN '​​​​🇹🇭 Таиланд'\n    WHEN 'ОАЭ' THEN '🇦🇪 ОАЭ'\n    WHEN 'Москва' THEN '​​🇷🇺 Москва'\n    WHEN 'СПб' THEN '​​​​​​​​​🏛️ СПб'\n    WHEN 'Грузия' THEN '​​​​​🇬🇪 Грузия'\n    WHEN 'Сочи' THEN '​​​​​​🏖 Сочи'\n    WHEN 'Кипр' THEN '​​​​​​​​🇨🇾 Кипр'\n    WHEN 'Турция' THEN '​​​​​​​🇹🇷 Турция'\n    ELSE [geo]\nEND",
          "guid_formula": "CASE [geo_o6vm]\n    WHEN 'Бали' THEN '​​​🇮🇩 Бали'\n    WHEN 'Таиланд' THEN '​​​​🇹🇭 Таиланд'\n    WHEN 'ОАЭ' THEN '🇦🇪 ОАЭ'\n    WHEN 'Москва' THEN '​​🇷🇺 Москва'\n    WHEN 'СПб' THEN '​​​​​​​​​🏛️ СПб'\n    WHEN 'Грузия' THEN '​​​​​🇬🇪 Грузия'\n    WHEN 'Сочи' THEN '​​​​​​🏖 Сочи'\n    WHEN 'Кипр' THEN '​​​​​​​​🇨🇾 Кипр'\n    WHEN 'Турция' THEN '​​​​​​​🇹🇷 Турция'\n    ELSE [geo_o6vm]\nEND",
