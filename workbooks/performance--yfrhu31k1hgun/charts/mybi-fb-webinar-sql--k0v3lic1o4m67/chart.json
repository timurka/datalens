    "queryValue": "-- Отчет по вебинару из источника FB\n\nSELECT crm_id,\n       creation_date_time,\n       utmsource,\n       utm_campaign,\n       utm_content,\n       qual,\n       status,\n       priority\nFROM perfomance_all_leads p\nLEFT JOIN amocrm_leads_tags l ON p.leads_id = l.leads_id\nWHERE p.pipeline_id = '5987164'\n      AND l.name = {{webinar_name}} -- Тег = название вебинара\n      AND utm_source IS NOT NULL\n      AND creation_date > {{interval_from}}\n      AND creation_date < {{interval_to}}\n      AND utmsource = 'fb' \n      \nORDER BY creation_date_time DESC",
    "queries": [],
    "params": [
      {
        "type": "string",
        "name": "source",
        "defaultValue": "fb"
      },
      {
        "type": "string",
        "name": "webinar_name",
        "defaultValue": "webinar21"
      },
      {
        "type": "date-interval",
        "name": "interval",
        "defaultValue": {
          "from": "2024-11-12T00:00:00.000Z",
          "to": "2024-11-15T00:00:00.000Z"
        }
      }
    ],
