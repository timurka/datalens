        "description": "",
        "lock_aggregation": false,
        "aggregation_locked": true,
        "formula": "IF [geo] = 'ОАЭ' THEN\n    IF SUM([followers_uae]) > 0 THEN\n        CONCAT(MIN([placement_order_uae]), ' раз.: ', \n        ROUND(SUM([cost]) / SUM([followers_uae]), 1),\n        ' ₽ (',\n        COUNT([date]),\n        ')')\n    ELSE\n        CONCAT(MIN([placement_order_uae]), ' раз.: ', \n        0,\n        ' ₽ (',\n        COUNT([date]),\n        ')')\n    END\n\nELSEIF [geo] = 'Москва' THEN\n    IF SUM([followers_msc]) > 0 THEN\n        CONCAT(MIN([placement_order_msc]), ' раз.: ', \n        ROUND(SUM([cost]) / SUM([followers_msc]), 1),\n        ' ₽ (',\n        COUNT([date]),\n        ')')\n    ELSE\n        CONCAT(MIN([placement_order_msc]), ' раз.: ', \n        0,\n        ' ₽ (',\n        COUNT([date]),\n        ')')\n    END\n\nELSEIF [geo] = 'ОАЭ + Москва' THEN\n    IF [F] > 0 THEN\n        CONCAT(MIN([placement_order_general]), ' раз.: ', \n        ROUND(SUM([cost]) / SUM([F]), 1),\n        ' ₽ (',\n        COUNT([date]),\n        ')')\n    ELSE\n        CONCAT(MIN([placement_order_general]), ' раз.: ', \n        0,\n        ' ₽ (',\n        COUNT([date]),\n        ')')\n    END\nEND\n\n",
        "guid_formula": "IF [geo] = 'ОАЭ' THEN\n    IF SUM([followers_uae_e3p4]) > 0 THEN\n        CONCAT(MIN([placement_order_uae_c1oo]), ' раз.: ', \n        ROUND(SUM([cost_03ph]) / SUM([followers_uae_e3p4]), 1),\n        ' ₽ (',\n        COUNT([date_scth]),\n        ')')\n    ELSE\n        CONCAT(MIN([placement_order_uae_c1oo]), ' раз.: ', \n        0,\n        ' ₽ (',\n        COUNT([date_scth]),\n        ')')\n    END\n\nELSEIF [geo] = 'Москва' THEN\n    IF SUM([followers_msc_5l83]) > 0 THEN\n        CONCAT(MIN([placement_order_msc_mlfw]), ' раз.: ', \n        ROUND(SUM([cost_03ph]) / SUM([followers_msc_5l83]), 1),\n        ' ₽ (',\n        COUNT([date_scth]),\n        ')')\n    ELSE\n        CONCAT(MIN([placement_order_msc_mlfw]), ' раз.: ', \n        0,\n        ' ₽ (',\n        COUNT([date_scth]),\n        ')')\n    END\n\nELSEIF [geo] = 'ОАЭ + Москва' THEN\n    IF [9bf229d0-7eea-11ee-908d-a9a9a0d07b54] > 0 THEN\n        CONCAT(MIN([placement_order_general_z7nk]), ' раз.: ', \n        ROUND(SUM([cost_03ph]) / SUM([9bf229d0-7eea-11ee-908d-a9a9a0d07b54]), 1),\n        ' ₽ (',\n        COUNT([date_scth]),\n        ')')\n    ELSE\n        CONCAT(MIN([placement_order_general_z7nk]), ' раз.: ', \n        0,\n        ' ₽ (',\n        COUNT([date_scth]),\n        ')')\n    END\nEND\n\n",
        "calc_mode": "formula",
