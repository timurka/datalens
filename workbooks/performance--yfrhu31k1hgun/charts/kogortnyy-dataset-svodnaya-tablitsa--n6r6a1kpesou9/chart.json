          "formula": "IF [day_bucket] = 0 THEN -- Служебный бакет. Показываем все лиды\n    STR([Размер когорты])\n\n-- По дням\nELSE\n    -- Конверсии\n    IF [metrics_bool] THEN\n        -- Кумулятивные\n        IF [csum] THEN\n            CONCAT(STR([Кум. конверсия]), '%')\n\n        ELSE\n            CONCAT(STR([Дневная конверсия]), '%')\n        END\n\n    -- Целые\n    ELSE\n        IF [csum] THEN\n            STR([Кум. квалы])\n        ELSE\n            STR([Дневные квалы])\n        END\n    END\n\nEND",
