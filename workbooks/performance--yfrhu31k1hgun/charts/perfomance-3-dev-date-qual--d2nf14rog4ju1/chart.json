              "managed_by": "user",
              "type": "DIMENSION",
              "guid_formula": "IF [duplicate_lead_id_qhim] IS NOT NULL \n    AND [internal_lead_id_kg3t] != [leads_id_bnq0]\n    AND ([source_deal_v494] != \"Instagram. Валидация\"\n        OR\n        [source_deal_v494] = 'Валидация')\n    THEN\n-- Вставляем дату оригинала\n    [lead_creation_date_gwo7]\n    \nELSEIF [creation_date_cmm4] IS NOT NULL THEN\n-- Если без оригинала (первоисточника) - дату создания лида\n    [creation_date_cmm4]\n\n-- Рекламные источники\nELSEIF [day_6mrt] IS NOT NULL AND [total_cost_ph1b] > 0 THEN\n    [day_6mrt]\n\n-- Facebook ads country\nELSEIF [date_1_pili] IS NOT NULL AND [spend_oht4] > 0 THEN\n    [date_1_pili]\n\nELSEIF [country_date_dwsz] IS NOT NULL AND [d99e5bb0-95b4-11ee-bd29-d94a523ffdc5] > 0 THEN\n    [country_date_dwsz]\nEND",
              "formula": "IF [original_id] IS NOT NULL \n    AND [original_internal_id] != [leads_id]\n    AND ([source_deal] != \"Instagram. Валидация\"\n        OR\n        [source_deal] = 'Валидация')\n    THEN\n-- Вставляем дату оригинала\n    [original_date]\n    \nELSEIF [creation_date] IS NOT NULL THEN\n-- Если без оригинала (первоисточника) - дату создания лида\n    [creation_date]\n\n-- Рекламные источники\nELSEIF [day] IS NOT NULL AND [total_cost] > 0 THEN\n    [day]\n\n-- Facebook ads country\nELSEIF [fbdb_date] IS NOT NULL AND [fbdb_spend] > 0 THEN\n    [fbdb_date]\n\nELSEIF [country_date] IS NOT NULL AND [country_cost] > 0 THEN\n    [country_date]\nEND",
              "calc_mode": "formula",
