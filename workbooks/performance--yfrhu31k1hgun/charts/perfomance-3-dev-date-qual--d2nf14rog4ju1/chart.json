              "guid_formula": "IF [utm_source_2_5au3] IS NOT NULL THEN\n    [utm_source_2_5au3]\n\nELSEIF [source_1_hvm8] IS NOT NULL THEN\n-- Берём из резервного поля\n    [source_1_hvm8]\n    \nELSEIF  [utm_source_1_zenu] IS NOT NULL THEN\n-- Из рекл. источника\n    [utm_source_1_zenu]\n\nELSEIF  [prioritized_sourcetag_fu7f] IS NOT NULL THEN\n-- Из тегов\n    [prioritized_sourcetag_fu7f]\n\nELSEIF [fb_campaign_id_cos9] IS NOT NULL THEN\n-- Фейсбук, если есть поле\n    \"fb\"\nELSE\n    \"(не определено)\"\nEND",
