          "formula": "IF [period] = 'Месяц' THEN\n    CASE DATEPART([date], \"month\")\n        WHEN 1 THEN CONCAT(\"Январь \", DATEPART([date], \"year\"))\n        WHEN 2 THEN CONCAT(\"Февраль \", DATEPART([date], \"year\"))\n        WHEN 3 THEN CONCAT(\"Март \", DATEPART([date], \"year\"))\n        WHEN 4 THEN CONCAT(\"Апрель \", DATEPART([date], \"year\"))\n        WHEN 5 THEN CONCAT(\"Май \", DATEPART([date], \"year\"))\n        WHEN 6 THEN CONCAT(\"Июнь \", DATEPART([date], \"year\"))\n        WHEN 7 THEN CONCAT(\"Июль \", DATEPART([date], \"year\"))\n        WHEN 8 THEN CONCAT(\"Август \", DATEPART([date], \"year\"))\n        WHEN 9 THEN CONCAT(\"Сентябрь \", DATEPART([date], \"year\"))\n        WHEN 10 THEN CONCAT(\"Октябрь \", DATEPART([date], \"year\"))\n        WHEN 11 THEN CONCAT(\"Ноябрь \", DATEPART([date], \"year\"))\n        WHEN 12 THEN CONCAT(\"Декабрь \", DATEPART([date], \"year\"))\n    END\nELSEIF [period] = 'Неделя' THEN\n    -- Выводим начало и конец недели\n    CONCAT(SPLIT(STR(DATETRUNC([date], \"week\")), \"-\", 3), '.', \n        SPLIT(STR(DATETRUNC([date], \"week\")), \"-\", 2), ' — ',\n        SPLIT(STR(DATEADD(DATETRUNC([date], \"week\"), 6)), '-', 3), '.', -- Добавляем 6 дней\n        SPLIT(STR(DATEADD(DATETRUNC([date], \"week\"), 6)), '-', 2), '.',\n        RIGHT(SPLIT(STR(DATEADD(DATETRUNC([date], \"week\"), 6)), '-', 1), 2)\n        )\nEND",
          "guid_formula": "IF [period] = 'Месяц' THEN\n    CASE DATEPART([date_scth], \"month\")\n        WHEN 1 THEN CONCAT(\"Январь \", DATEPART([date_scth], \"year\"))\n        WHEN 2 THEN CONCAT(\"Февраль \", DATEPART([date_scth], \"year\"))\n        WHEN 3 THEN CONCAT(\"Март \", DATEPART([date_scth], \"year\"))\n        WHEN 4 THEN CONCAT(\"Апрель \", DATEPART([date_scth], \"year\"))\n        WHEN 5 THEN CONCAT(\"Май \", DATEPART([date_scth], \"year\"))\n        WHEN 6 THEN CONCAT(\"Июнь \", DATEPART([date_scth], \"year\"))\n        WHEN 7 THEN CONCAT(\"Июль \", DATEPART([date_scth], \"year\"))\n        WHEN 8 THEN CONCAT(\"Август \", DATEPART([date_scth], \"year\"))\n        WHEN 9 THEN CONCAT(\"Сентябрь \", DATEPART([date_scth], \"year\"))\n        WHEN 10 THEN CONCAT(\"Октябрь \", DATEPART([date_scth], \"year\"))\n        WHEN 11 THEN CONCAT(\"Ноябрь \", DATEPART([date_scth], \"year\"))\n        WHEN 12 THEN CONCAT(\"Декабрь \", DATEPART([date_scth], \"year\"))\n    END\nELSEIF [period] = 'Неделя' THEN\n    -- Выводим начало и конец недели\n    CONCAT(SPLIT(STR(DATETRUNC([date_scth], \"week\")), \"-\", 3), '.', \n        SPLIT(STR(DATETRUNC([date_scth], \"week\")), \"-\", 2), ' — ',\n        SPLIT(STR(DATEADD(DATETRUNC([date_scth], \"week\"), 6)), '-', 3), '.', -- Добавляем 6 дней\n        SPLIT(STR(DATEADD(DATETRUNC([date_scth], \"week\"), 6)), '-', 2), '.',\n        RIGHT(SPLIT(STR(DATEADD(DATETRUNC([date_scth], \"week\"), 6)), '-', 1), 2)\n        )\nEND",
