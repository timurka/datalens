    "queryValue": "WITH perfomance_leads AS (\n  SELECT creation_date,\n    COUNT(leads_id) AS leads,\n    SUM(qual) AS quals\n  FROM perfomance_all_leads\n  WHERE utmsource = 'zakupka'\n    AND pipeline_id = 5987164\n    AND first_deal = 'Да'\n  GROUP BY creation_date\n),\n\ndaily_followers AS (\n  SELECT z.date, \n         SUM(followers_msc + followers_uae + followers_bali) AS total_daily_followers,\n         AVG(p.leads) AS daily_leads,\n         AVG(p.quals) AS daily_quals\n  FROM zakupki z\n  LEFT JOIN perfomance_leads p ON p.creation_date = z.date\n  WHERE z.date >= {{interval_from}}\n    AND z.date <= {{interval_to}}\n  GROUP BY z.date\n),\n\naggregated_data AS (\nSELECT z.channel_link AS tgurl,\n    MIN(z.channel_name) AS \"Название канала\",\n    MIN(zi.category) AS \"Категория\",\n    COUNT(z.channel_link) AS \"Размещений\",\n    SUM(z.cost) AS \"Расход\",\n    AVG(participants_count) AS \"Аудитория\",\n    SUM(z.followers_msc + z.followers_uae + z.followers_bali) AS \"F\",\n   \n    ROUND(SUM(z.cost) / NULLIF(SUM(z.followers_msc + z.followers_uae + z.followers_bali), 0), 0) AS \"CPF\",\n    \n    SUM(df.total_daily_followers) AS \"Общее количество новых подписчиков\",\n    \n    ROUND(SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0) * 100, 2) AS \"Доля подписчиков от всех\",\n    \n    ROUND(SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(AVG(participants_count), 0) * 100, 2) AS \"Доля от аудитории\",\n    SUM(df.daily_leads) AS \"Лидов в дни размещений\",\n    \n    ROUND(SUM(df.daily_leads) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0)), 2) AS \"Доля лидов\",\n    \n    ROUND(SUM(z.cost) / NULLIF((SUM(df.daily_leads) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0))), 0), 0) AS \"CPL\",\n    \n    SUM(df.daily_quals) AS \"Квалов в дни размещений\",\n    \n    ROUND(SUM(df.daily_quals) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0)), 2) AS \"Доля квалов\",\n    \n    ROUND(SUM(z.cost) / NULLIF((SUM(df.daily_quals) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0))), 0), 0) AS \"CPQ\"\n    \nFROM zakupki z\n\nLEFT JOIN perfomance_leads p ON p.creation_date = z.date\nLEFT JOIN webhook_zakupki_channels_stat zc ON zc.channel_url = z.channel_link\nLEFT JOIN daily_followers df ON z.date = df.date\nLEFT JOIN webhook_zakupki_channels_info zi ON zi.channel_url = z.channel_link\n\nWHERE z.date >= {{interval_from}}\n    AND z.date <= {{interval_to}}\n    AND z.channel_link IS NOT NULL\n   -- AND zc.channel_url IS NOT NULL\nGROUP BY z.channel_link\n),\n\n\naverage_values AS (\n  SELECT\n      AVG(\"Размещений\") AS avg_placements,\n      AVG(\"Расход\") AS avg_cost,\n      AVG(\"Аудитория\") AS avg_audience,\n      AVG(\"F\") AS avg_f,\n      AVG(\"CPF\") AS avg_cpf,\n      AVG(\"Общее количество новых подписчиков\") AS avg_total_new_followers,\n      AVG(\"Доля подписчиков от всех\") AS avg_share_of_all_subscribers,\n      AVG(\"Доля от аудитории\") AS avg_share_of_audience,\n      AVG(\"Лидов в дни размещений\") AS avg_daily_leads,\n      AVG(\"Доля лидов\") AS avg_share_of_leads,\n      AVG(\"CPL\") AS avg_cpl,\n      AVG(\"Квалов в дни размещений\") AS avg_daily_quals,\n      AVG(\"Доля квалов\") AS avg_share_of_quals,\n      AVG(\"CPQ\") AS avg_cpq\n  FROM aggregated_data\n)\n\nSELECT\n    ROW_NUMBER() OVER (ORDER BY ad.\"Размещений\" DESC) AS N,\n    ad.tgurl AS url,\n    ad.\"Категория\",\n    ad.\"Название канала\",\n    ad.\"Размещений\",\n    ad.\"Расход\",\n    ad.\"Аудитория\",\n    ad.\"F\",\n    ad.\"CPF\",\n    ad.\"Общее количество новых подписчиков\" AS \"Подписчиков в дни размещений\",\n    ad.\"Доля подписчиков от всех\",\n    ad.\"Доля от аудитории\",\n    ad.\"Лидов в дни размещений\" AS \"Лидов\",\n    ad.\"Доля лидов\",\n    ad.\"CPL\",\n    ROUND((ad.\"CPL\" - av.avg_cpl), 0) AS \"Δ CPL\",\n    ad.\"Квалов в дни размещений\" AS \"Квалов\",\n    ad.\"Доля квалов\",\n    ad.\"CPQ\",\n    ROUND((ad.\"CPQ\" - av.avg_cpq), 0) AS \"Δ CPQ\"\nFROM aggregated_data ad\nCROSS JOIN average_values av\nORDER BY ad.\"Размещений\" DESC\nLIMIT {{limits}}",
    "queries": [],
