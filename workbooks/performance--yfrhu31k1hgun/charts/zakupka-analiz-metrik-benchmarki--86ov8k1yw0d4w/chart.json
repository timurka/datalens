    "queryValue": "WITH perfomance_leads AS (\n  SELECT creation_date,\n    COUNT(leads_id) AS leads,\n    SUM(qual) AS quals\n  FROM perfomance_all_leads\n  WHERE utmsource = 'zakupka'\n    AND pipeline_id = 5987164\n    AND first_deal = 'Да'\n  GROUP BY creation_date\n),\n\ndaily_followers AS (\n  SELECT z.date, \n         SUM(followers_msc + followers_uae + followers_bali) AS total_daily_followers,\n         AVG(p.leads) AS daily_leads,\n         AVG(p.quals) AS daily_quals\n  FROM zakupki z\n  LEFT JOIN perfomance_leads p ON p.creation_date = z.date\n  WHERE z.date >= {{interval_from}}\n    AND z.date <= {{interval_to}}\n  GROUP BY z.date\n),\n\naggregated_data AS (\nSELECT z.channel_link,\n    COUNT(z.channel_link) AS \"Размещений\",\n    SUM(z.cost) AS \"Расход\",\n    AVG(participants_count) AS \"Аудитория\",\n    SUM(z.followers_msc + z.followers_uae + z.followers_bali) AS \"F\",\n    ROUND(SUM(z.cost) / NULLIF(SUM(z.followers_msc + z.followers_uae + z.followers_bali), 0), 0) AS \"CPF\",\n    \n    SUM(df.total_daily_followers) AS \"Общее количество новых подписчиков\",\n    ROUND(SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0) * 100, 2) AS \"Доля подписчиков от всех\",\n    ROUND(SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(AVG(participants_count), 0) * 100, 2) AS \"Доля от аудитории\",\n    SUM(df.daily_leads) AS \"Лидов в дни размещений\",\n    ROUND(SUM(df.daily_leads) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0)), 2) AS \"Доля лидов\",\n    \n    ROUND(SUM(z.cost) / NULLIF((SUM(df.daily_leads) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0))), 0), 0) AS \"CPL\",\n    \n    SUM(df.daily_quals) AS \"Квалов в дни размещений\",\n    \n    ROUND(SUM(df.daily_quals) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0)), 2) AS \"Доля квалов\",\n    \n    ROUND(SUM(z.cost) / NULLIF((SUM(df.daily_quals) * (SUM(z.followers_msc + z.followers_uae + z.followers_bali) / NULLIF(SUM(df.total_daily_followers), 0))), 0), 0) AS \"CPQ\"\n    \nFROM zakupki z\nLEFT JOIN perfomance_leads p ON p.creation_date = z.date\nLEFT JOIN webhook_zakupki_channels_stat zc ON zc.channel_url = z.channel_link\nLEFT JOIN daily_followers df ON z.date = df.date\nWHERE z.date >= {{interval_from}}\n    AND z.date <= {{interval_to}}\n    AND z.channel_link IS NOT NULL\n --   AND zc.channel_url IS NOT NULL\nGROUP BY z.channel_link\n)\n\nSELECT\n    AVG(\"Размещений\") AS \"Среднее число размещений\",\n    AVG(\"Расход\") AS \"Средний расход\",\n    AVG(\"Аудитория\") AS \"Средняя аудитория\",\n    AVG(\"F\") AS \"Среднее F\",\n   -- AVG(\"CPF\") AS \"Средний CPF\",\n   ROUND(SUM(\"Расход\") / NULLIF(SUM(\"F\"), 0), 0) AS \"Средний CPF\",\n    AVG(\"Общее количество новых подписчиков\") AS \"Среднее общее количество новых F\",\n    AVG(\"Доля подписчиков от всех\") AS \"Средняя доля подписчиков от всех\",\n    AVG(\"Доля от аудитории\") AS \"Средняя доля от аудитории\",\n    AVG(\"Лидов в дни размещений\") AS \"Ср. кол-во лидов в дни размещений\",\n    AVG(\"Доля лидов\") AS \"Средняя доля лидов\",\n    AVG(\"CPL\") AS \"Средний CPL\",\n    AVG(\"Квалов в дни размещений\") AS \"Ср. кол-во квалов в дни размещений\",\n    AVG(\"Доля квалов\") AS \"Средняя доля квалов\",\n    AVG(\"CPQ\") AS \"Средний CPQ\"\nFROM aggregated_data",
