      "pagination": "on",
      "limit": 100
    },
    "queryValue": "SELECT\n    p.crm_id AS \"CRM ID\",\n    p.pipeline_id,\n    MAX(p.utmsource) AS \"Последний источник\",\n    LEFT(MAX(p.password), 50) AS \"Пароль\",\n    MAX(c.name) AS \"ФИО\",\n    MAX(CASE WHEN le.attribute_id = '989731' THEN le.value END) AS \"Тип покупателя\",\n    MAX(CASE WHEN le.attribute_id = '991039' THEN le.value END) AS \"Город\",\n    MAX(CASE WHEN le.attribute_id = '991091' THEN le.value END) AS \"Застройщик\",\n    MAX(CASE WHEN le.attribute_id = '990557' THEN le.value END) AS \"Объект\",\n    MAX(CASE WHEN le.attribute_id = '991041' THEN le.value END) AS \"Тип недвижимости\",\n    MAX(CASE WHEN le.attribute_id = '990553' THEN le.value END) AS \"Тип покупки\",\n    MAX(CASE WHEN le.attribute_id = '989737' THEN le.value END) AS \"Срок сдачи\",\n    MAX(CASE WHEN le.attribute_id = '989739' THEN le.value END) AS \"Срок выхода на сделку\",\n    MAX(CASE WHEN le.attribute_id = '916379' THEN le.value END) AS \"Что важно в покупке\",\n    MAX(CASE WHEN le.attribute_id = '989743' THEN le.value END) AS \"Способ оплаты\",\n    MAX(CASE WHEN le.attribute_id = '991037' OR le.attribute_id = '673655' THEN le.value END) AS \"Сумма сделки\",\n    MAX(CASE WHEN le.attribute_id = '978575' OR le.attribute_id = '673773' THEN le.value END) AS \"Приоритет\",\n    MAX(p.date_booking) AS \"Дата брони\",\n    COALESCE(MAX(p.lead_creation_date), MAX(p.creation_date)) AS \"Дата создания лида\",\n    MAX(p.lead_source) AS \"Источник лида\"\nFROM\n    perfomance_all_leads p\nLEFT JOIN \n    amocrm_leads_facts lf ON p.leads_id = lf.leads_id\nLEFT JOIN \n    amocrm_contacts c ON c.id = lf.contacts_id\nRIGHT JOIN\n    amocrm_leads_attributes le ON p.leads_id = le.leads_id\nWHERE\n    p.booking_event = 1 AND p.date_booking IS NOT NULL\nGROUP BY\n    p.crm_id, p.pipeline_id\nHAVING \n    MAX(CASE WHEN le.attribute_id = '990539' OR le.attribute_id = '1213281' THEN DATE(le.value) END) IS NOT NULL\nORDER BY\n    \"Дата брони\" DESC",
    "queries": [],
    "params": [
      {
        "type": "date-interval",
        "name": "dates",
        "defaultValue": {
          "from": "__relative_-6d",
          "to": "__relative_-0d"
        }
      }
    ],
