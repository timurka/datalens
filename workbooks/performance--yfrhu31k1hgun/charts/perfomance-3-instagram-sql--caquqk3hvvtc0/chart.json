    "queryValue": "WITH nickname AS (\n  -- Никнеймы инсты, если есть\n  SELECT contacts_id,\n         value\n  FROM amocrm_contacts_attributes\n  WHERE name = 'Instagram_WZ'\n)\n\nSELECT \n       ROW_NUMBER() OVER (ORDER BY COALESCE(p.lead_creation_date, p.creation_date) DESC) AS N, -- Порядковый номер\n       COALESCE(p.lead_creation_date, p.creation_date) AS \"Дата лида\", -- Дата создания лида\n       n.value AS \"Аккаунт\", -- Никнейм Инстаграма\n       c.phone AS \"Телефон\",\n       p.qual AS \"Квал\",\n       p.priority AS \"Приоритет\",\n       DATE(p.date_qual) AS \"Дата квала\",\n       p.booking_event AS \"Бронь\",\n       p.password AS \"Пароль\",\n       p.source_deal AS \"Воронка\",\n       p.utmsource AS \"Источник\",\n       p.crm_id AS \"AMO ID\"\n       \nFROM perfomance_all_leads p\nLEFT JOIN amocrm_leads_facts lf ON p.leads_id = lf.leads_id\nLEFT JOIN amocrm_contacts c ON c.id = lf.contacts_id\nLEFT JOIN nickname n ON n.contacts_id = c.id\nWHERE qual = 1\n      AND p.utmsource = 'instagram'\n      AND {{dates_from}} <= COALESCE(p.lead_creation_date, p.creation_date)\n      AND {{dates_to}} >= COALESCE(p.lead_creation_date, p.creation_date)\nORDER BY COALESCE(p.lead_creation_date, p.creation_date) DESC\n",
    "queries": [],
    "params": [
      {
        "type": "date-interval",
        "name": "dates",
        "defaultValue": {
          "from": "__relative_-6d",
          "to": "__relative_-0d"
        }
      }
    ],
