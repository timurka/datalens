    "queryValue": "SELECT \n    ROW_NUMBER() OVER (ORDER BY COALESCE(p.lead_creation_date, p.creation_date) DESC) AS N,\n    p.crm_id as \"CRM ID\", \n    COALESCE(p.lead_creation_date, p.creation_date) as \"Дата создания\",\n    al.value as \"Lead ID\",\n    DATE(p.date_qual) AS \"Дата квала\",\n    p.priority AS Приоритет,\n    p.source_deal AS Источник\n\nFROM perfomance_all_leads p\nLEFT JOIN public.amocrm_leads_attributes al ON p.leads_id = al.leads_id\n\nWHERE utmsource = 'marketcall'\n      AND qual = 1 \n      AND al.attribute_id = '1001907'\n      -- параметр интервала дат\n      AND {{interval_from}} <= COALESCE(p.lead_creation_date, p.creation_date) AND COALESCE(p.lead_creation_date, p.creation_date) <= {{interval_to}}\n      \nORDER BY COALESCE(p.lead_creation_date, p.creation_date) DESC\n",
