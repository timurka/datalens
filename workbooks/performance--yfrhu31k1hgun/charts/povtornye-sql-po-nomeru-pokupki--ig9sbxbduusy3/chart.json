    "queryValue": "WITH\n-- 0) Параметры\nlist_p AS (\n  SELECT\n    CASE\n      WHEN regexp_replace($$ {{geo_list}} $$,'E''|''|\\(|\\)|\\s','', 'g') = ''\n        THEN NULL\n      ELSE string_to_array(\n             regexp_replace($$ {{geo_list}} $$,'E''|''|\\(|\\)|\\s','', 'g'),\n             ','\n           )::text[]\n    END AS geo_arr\n),\nparam_p AS (\n  SELECT COALESCE({{date_book_interval}}, 0)::int AS book_window_days\n),\n\n-- 1) Все повторные покупки ГЛОБАЛЬНО (учёт окна сессий)\nall_repeats AS (\n  SELECT\n    v.person_key,\n    v.crm_id,\n    v.booking_date,\n    v.prev_booking_date,\n    v.deal_amount,\n    v.geo,\n    (v.booking_date::date - v.prev_booking_date::date) AS days_gap\n  FROM v_person_purchases_prev v\n  WHERE v.prev_booking_date IS NOT NULL\n    AND (v.booking_date::date - v.prev_booking_date::date) > (SELECT book_window_days FROM param_p)\n),\n\n-- 2) Нумерация повтора внутри клиента (1-й повтор = вторая покупка и т.д.)\nrepeats_numbered AS (\n  SELECT\n    ar.*,\n    ROW_NUMBER() OVER (PARTITION BY ar.person_key ORDER BY ar.booking_date) AS repeat_no\n  FROM all_repeats ar\n),\n\n-- 3) Фильтр отчёта: GEO + интервал (какие повторы попадают в выборку)\nreport_repeats AS (\n  SELECT rn.*\n  FROM repeats_numbered rn\n  CROSS JOIN list_p lp\n  WHERE rn.geo IN ('ОАЭ','Москва','Грузия','Таиланд','Бали','Таиланд Eng')\n    AND (lp.geo_arr IS NULL OR rn.geo = ANY(lp.geo_arr))\n    AND rn.booking_date >= {{interval_from}}::date\n    AND rn.booking_date <  {{interval_to}}::date\n)\n\n-- 4) Агрегация по номеру повтора (1..4)\nSELECT\n  rr.repeat_no                                         AS \"Номер повтора\",\n  COUNT(*)                                             AS \"Количество брони\",\n  percentile_disc(0.5) WITHIN GROUP (ORDER BY rr.deal_amount)\nAS \"Медианный чек (deal_amount)\",\n  SUM(rr.deal_amount)                                  AS \"Сумма всех сделок\",\n  percentile_disc(0.5) WITHIN GROUP (ORDER BY rr.days_gap) AS \"Медиана разрыва (дней)\"\nFROM report_repeats rr\nWHERE rr.repeat_no BETWEEN 1 AND 4\nGROUP BY rr.repeat_no\nORDER BY rr.repeat_no\n",
    "queries": [],
