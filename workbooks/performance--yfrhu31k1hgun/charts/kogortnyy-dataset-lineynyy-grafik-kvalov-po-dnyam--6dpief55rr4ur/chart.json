          "aggregation_locked": true,
          "lock_aggregation": false,
          "formula": "IF [day_bucket] = 0 THEN -- Служебный бакет. Показываем все лиды\n    STR([Размер когорты])\n\n-- По дням\nELSE\n    -- Конверсии\n    IF [metrics_bool] THEN\n        -- Кумулятивные\n        IF [csum] THEN\n            CONCAT(STR([Кум. конверсия]), '%')\n\n        ELSE\n            CONCAT(STR([Дневная конверсия]), '%')\n        END\n\n    -- Целые\n    ELSE\n        IF [csum] THEN\n            STR([Кум. квалы])\n        ELSE\n            STR([Дневные квалы])\n        END\n    END\n\nEND",
          "guid_formula": "IF [day_bucket_w9fu] = 0 THEN -- Служебный бакет. Показываем все лиды\n    STR([c7cefc00-4634-11f0-ba2b-c1c443aca8dc])\n\n-- По дням\nELSE\n    -- Конверсии\n    IF [metrics_bool] THEN\n        -- Кумулятивные\n        IF [csum] THEN\n            CONCAT(STR([09b67990-4635-11f0-ba2b-c1c443aca8dc]), '%')\n\n        ELSE\n            CONCAT(STR([30d19b80-4695-11f0-884a-4963b5179be9]), '%')\n        END\n\n    -- Целые\n    ELSE\n        IF [csum] THEN\n            STR([d9da4710-4634-11f0-ba2b-c1c443aca8dc])\n        ELSE\n            STR([b4e07ce0-4634-11f0-ba2b-c1c443aca8dc])\n        END\n    END\n\nEND",
