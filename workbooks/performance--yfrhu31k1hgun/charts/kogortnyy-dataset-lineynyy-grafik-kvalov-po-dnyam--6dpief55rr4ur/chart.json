          "aggregation_locked": true,
          "lock_aggregation": false,
          "formula": "IF sum([qual_cnt_on_day]) > 0 THEN\n    ROUND(\n            (100 * RSUM(SUM([qual_cnt_on_day]) WITHIN [Период] ORDER BY [day_bucket]) / SUM(SUM([cohort_cnt])))\n            * 100\n        ) / 100.0\nEND",
